//Bruteforce Approach

class Solution {
    public int cherryPickup(int[][] grid) {
        // Start the recursion from the first row with Robot 1 at column 0 and Robot 2 at the last column.
        return cherryPickup(grid, 0, 0, grid[0].length - 1, grid.length, grid[0].length);
    }

    private int cherryPickup(int[][] grid, int row, int robot1Col, int robot2Col, int m, int n) {
        //Base case: If we reach the last row, collect cherries from the current positions of both robots.
        if (row == m - 1) {
            // Robots are in different cells; sum up cherries from both cells.
            if (robot1Col != robot2Col) {
                return grid[row][robot1Col] + grid[row][robot2Col];
            }

            // Both robots are in the same cell; count cherries only once.
            return grid[row][robot1Col];
        }

        int maxCherries = 0;
        /*
         * At each step, both robots move independently.
         *
         * - Robot1 can move to:
         *     → col1 - 1 (left)
         *     → col1     (down)
         *     → col1 + 1 (right)
         *
         * - Robot2 can also move to:
         *     → col2 - 1
         *     → col2
         *     → col2 + 1
         *
         * - Since both move independently, we combine their moves:
         *
         *   All 9 possible combinations:
         *
         *   1. (col1 - 1, col2 - 1)
         *   2. (col1 - 1, col2)
         *   3. (col1 - 1, col2 + 1)
         *
         *   4. (col1,     col2 - 1)
         *   5. (col1,     col2)
         *   6. (col1,     col2 + 1)
         *
         *   7. (col1 + 1, col2 - 1)
         *   8. (col1 + 1, col2)
         *   9. (col1 + 1, col2 + 1)
         *
         * - Each pair represents the next positions of (Robot1, Robot2).
         *
         * - We must explore all valid combinations (within bounds)
         *   and choose the one that gives the maximum cherries.
         */
        for (int move1 = -1; move1 <= 1; move1++) {
            for (int move2 = -1; move2 <= 1; move2++) {
                int nextRobot1Col = robot1Col + move1;
                int nextRobot2Col = robot2Col + move2;

                // Ensure that the next path is within the grid bounds.
                if (nextRobot1Col >= 0 && nextRobot1Col < n && nextRobot2Col >= 0 && nextRobot2Col < n) {
                    // Recursively calculate the maximum cherries collected starting from the next row considering all possible moves for both robots.
                    int maxCherriesFromFuture = cherryPickup(grid, row + 1, nextRobot1Col, nextRobot2Col, m, n);
                    /*
                    * Total cherries collected at this step:
                    *
                    * - Add cherries collected by Robot1 from its current cell.
                    *
                    * - Add cherries collected by Robot2 ONLY if both robots
                    *   are on different cells (to avoid double counting).
                    *
                    * - Add the maximum cherries that can be collected
                    *   from future rows (computed recursively).
                    */
                    int totalCherries = grid[row][robot1Col] + (robot1Col != robot2Col ? grid[row][robot2Col] : 0) + maxCherriesFromFuture;
                    // Update the maximum cherries collected.
                    maxCherries = Math.max(maxCherries, totalCherries);
                }
            }
        }

        return maxCherries;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[row][robot1Col][robot2Col] stores the maximum cherries that can be collected
    * starting from the given state where:
    *     → row = current row
    *     → robot1Col = column of Robot1
    *     → robot2Col = column of Robot2
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum cherries collectible from this state to the last row
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][robot1Col][robot2Col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][][] dp;

    public int cherryPickup(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        dp = new Integer[m][n][n];
        return cherryPickup(grid, 0, 0, n - 1, m, n);
    }

    private int cherryPickup(int[][] grid, int row, int robot1Col, int robot2Col, int m, int n) {
        if (row == m - 1) {
            if (robot1Col != robot2Col) {
                return grid[row][robot1Col] + grid[row][robot2Col];
            }

            return grid[row][robot1Col];
        }

        if (dp[row][robot1Col][robot2Col] != null) {
            return dp[row][robot1Col][robot2Col];
        }

        int maxCherries = 0;

        for (int move1 = -1; move1 <= 1; move1++) {
            for (int move2 = -1; move2 <= 1; move2++) {
                int nextRobot1Col = robot1Col + move1;
                int nextRobot2Col = robot2Col + move2;

                if (nextRobot1Col >= 0 && nextRobot1Col < n && nextRobot2Col >= 0 && nextRobot2Col < n) {
                    int maxCherriesFromFuture = cherryPickup(grid, row + 1, nextRobot1Col, nextRobot2Col, m, n);
                    int totalCherries = grid[row][robot1Col] + (robot1Col != robot2Col ? grid[row][robot2Col] : 0) + maxCherriesFromFuture;
                    maxCherries = Math.max(maxCherries, totalCherries);
                }
            }
        }

        return dp[row][robot1Col][robot2Col] = maxCherries;
    }
}


