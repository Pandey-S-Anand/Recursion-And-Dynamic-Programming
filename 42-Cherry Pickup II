//Naive implementation

class Solution {
    public int cherryPickup(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        int[][][] dp = new int[m][n][n];

        for (int col = 0; col < n; col++) {
            for (int robot1Col = n - 1; robot1Col >= 0; robot1Col--) {
                for (int robot2Col = 0; robot2Col < n; robot2Col++) {
                    if (robot1Col != robot2Col) {
                        dp[m - 1][robot1Col][robot2Col] = grid[m - 1][robot1Col] + grid[m - 1][robot2Col];
                    } else {
                        dp[m - 1][robot1Col][robot2Col] = grid[m - 1][robot1Col];
                    }
                }
            }
        }

        for (int row = m - 2; row >= 0; row--) {
            for (int robot1Col = n - 1; robot1Col >= 0; robot1Col--) {
                for (int robot2Col = 0; robot2Col < n; robot2Col++) {
                    int maxCherries = 0;

                    for (int move1 = -1; move1 <= 1; move1++) {
                        for (int move2 = -1; move2 <= 1; move2++) {
                            int nextRobot1Col = robot1Col + move1;
                            int nextRobot2Col = robot2Col + move2;

                            if (nextRobot1Col >= 0 && nextRobot1Col < n && nextRobot2Col >= 0 && nextRobot2Col < n) {
                                int maxCherriesFromFuture = dp[row + 1][nextRobot1Col][nextRobot2Col];
                                int totalCherries = grid[row][robot1Col] + (robot1Col != robot2Col ? grid[row][robot2Col] : 0) + maxCherriesFromFuture;
                                maxCherries = Math.max(maxCherries, totalCherries);
                            }
                        }
                    }
                    dp[row][robot1Col][robot2Col] = maxCherries;
                }
            }
        }

        return dp[0][0][n - 1];
    }
}


//Optimal implementation

class Solution {
    public int cherryPickup(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        /*
        * Space Optimization (from 3D → 2D):
        *
        * - In the 3D DP approach:
        *     dp[row][robot1Col][robot2Col] represents the maximum cherries  collectible from this state.
        *
        * - Transition:
        *     dp[row][c1][c2] depends only on the next row:
        *         → dp[row + 1][nextC1][nextC2]
        *
        * - Since the current state depends ONLY on the next row (row + 1),
        *   we do not need to store all rows in a 3D array.
        *
        * - Instead, we keep only two 2D arrays:
        *     → nextRow[c1][c2]    → represents dp[row + 1][c1][c2]
        *     → currentRow[c1][c2] → represents dp[row][c1][c2]
        *
        */
        int[][] currentRow = new int[n][n];
        int[][] nextRow = new int[n][n];

        for (int col = 0; col < n; col++) {
            for (int robot1Col = n - 1; robot1Col >= 0; robot1Col--) {
                for (int robot2Col = 0; robot2Col < n; robot2Col++) {
                    nextRow[robot1Col][robot2Col] = grid[m - 1][robot1Col];
                    if (robot1Col != robot2Col) {
                        nextRow[robot1Col][robot2Col] += grid[m - 1][robot2Col];
                    }
                }
            }
        }

        for (int row = m - 2; row >= 0; row--) {
            for (int robot1Col = n - 1; robot1Col >= 0; robot1Col--) {
                for (int robot2Col = 0; robot2Col < n; robot2Col++) {
                    int maxCherries = 0;

                    for (int move1 = -1; move1 <= 1; move1++) {
                        for (int move2 = -1; move2 <= 1; move2++) {
                            int nextRobot1Col = robot1Col + move1;
                            int nextRobot2Col = robot2Col + move2;

                            if (nextRobot1Col >= 0 && nextRobot1Col < n && nextRobot2Col >= 0 && nextRobot2Col < n) {
                                int maxCherriesFromFuture = nextRow[nextRobot1Col][nextRobot2Col];
                                int totalCherries = grid[row][robot1Col] + (robot1Col != robot2Col ? grid[row][robot2Col] : 0) + maxCherriesFromFuture;
                                maxCherries = Math.max(maxCherries, totalCherries);
                            }
                        }
                    }
                    currentRow[robot1Col][robot2Col] = maxCherries;
                }
            }

            int[][] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0][n - 1];
    }
}
