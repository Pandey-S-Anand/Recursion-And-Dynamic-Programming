//Bruteforce Approach

class Solution {
    public int jump(int[] arr) {
        // Start from index 0 and compute minimum jumps to reach the end
        return jump(arr, 0);
    }

    private int jump(int[] arr, int index) {
        // Base case: If we are already at the last index, no jumps are needed
        if (index == arr.length - 1) {
            return 0;
        }

        // Invalid case: If index goes out of bounds, this path is not valid 
        if (index >= arr.length) {
            return Integer.MAX_VALUE;
        }

        // Maximum jump length we can take from current index
        int maxJumpSize = arr[index];

        // Initialize minimum jumps as infinity (worst case)
        int minJumps = Integer.MAX_VALUE;

        // Try all possible jump sizes from 1 to maxJumpSize
        for (int jumpSize = 1; jumpSize <= maxJumpSize; jumpSize++) {
            // Recursively calculate jumps needed from the next position
            int jumps = jump(arr, index + jumpSize);

            // Take the minimum among all possible jump paths
            minJumps = Math.min(minJumps, jumps);
        }

        // Since a valid path is guaranteed, minJumps will be updated; add 1 for the current jump.      
        if (minJumps != Integer.MAX_VALUE) {
            return 1 + minJumps;
        }

        // If no valid path exists, return Integer.MAX_VALUE (unreachable)
        return minJumps;
    }
}


//Improved Approach

class Solution {
    /*
    * Memoization:
    * dp[index] stores the minimum number of jumps required to reach
    * the last index starting from the given index.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum jumps needed to reach the end from this index
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[index]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int jump(int[] arr) {
        dp = new Integer[arr.length - 1];
        return jump(arr, 0);
    }

    private int jump(int[] arr, int index) {
        if (index == arr.length - 1) {
            return 0;
        }

        if (index >= arr.length) {
            return Integer.MAX_VALUE;
        }

        if (dp[index] != null) {
            return dp[index];
        }

        int maxJumpSize = arr[index];
        int minJumps = Integer.MAX_VALUE;

        for (int jumpSize = 1; jumpSize <= maxJumpSize; jumpSize++) {
            int jumps = jump(arr, index + jumpSize);
            minJumps = Math.min(minJumps, jumps);
        }

        if (minJumps != Integer.MAX_VALUE) {
            return dp[index] = 1 + minJumps;
        }

        return dp[index] = minJumps;
    }
}


//Better Approach

class Solution {
    public int jump(int[] arr) {
        int[] dp = new int[arr.length];

        // dp[i] represents the minimum number of jumps required to reach the last index from index 'i'
        dp[arr.length - 1] = 0;

        for (int i = arr.length - 2; i >= 0; i--) {
            int minJumps = Integer.MAX_VALUE;

            for (int jumpSize = 1; jumpSize <= arr[i]; jumpSize++) {
                if ((i + jumpSize) >= arr.length) {
                    break;
                }
                int jumps = dp[i + jumpSize];
                minJumps = Math.min(minJumps, jumps);
            }

            if (minJumps != Integer.MAX_VALUE) {
                dp[i] = 1 + minJumps;
            } else {
                dp[i] = Integer.MAX_VALUE;
            }
        }

        return dp[0];
    }
}


//Optimal Approach (Greedy Approach)

class Solution {
    public int jump(int[] arr) {
        // Edge case: If the array has only one element, no jumps are needed.
        if (arr.length == 1) {
            return 0;
        }

        int maxReachableIndex = 0;
        int windowEndIndex = 0; // Represents the end of the current jump range (window).
        int minJump = 0;  // Keeps count of the minimum number of jumps.

        for (int i = 0; i < arr.length; i++) {
            // Update the max index reachable from the current index.
            maxReachableIndex = Math.max(maxReachableIndex, i + arr[i]);
            
            // When we've reached the end of the current jump range (window), we need to increase the jump count and update the range.
            if (i == windowEndIndex) {
                windowEndIndex = maxReachableIndex;
                minJump++;
                
                //Early exit : if the last index is reached 
                if (maxReachableIndex == arr.length - 1) {
                    break;
                }
            }
        }

        return minJump;
    }
}
