/*
You cannot hold multiple stocks at the same time. At the start, you are allowed to buy a stock because you currently do not own any.

On any given day when you have the option to buy, you have two choices:

Buy the stock: If you choose to buy on that day, you will not be able to buy again until you sell the stock you just acquired.
In this case, you should account for the purchase as a negative value (since profit is calculated as sell price minus buy price).
Not buy the stock: If you decide not to buy, you still retain the option to purchase the stock on a future day.

On any given day when you donot have the option to buy the stock(it means you already hold a stock.), In this situation, you also have two options:

Sell the stock: If you choose to sell on that day, you can then buy a stock again in the future.
You would add the selling price as a positive value (since profit is calculated as sell price minus buy price).
Not sell the stock: If you choose not to sell, you cannot buy any other stock until you sell the one you currently hold.

When we reach the end of the index, In this case, the maximum profit will be 0, as there are no more days left to make any trades.
*/

//Bruteforce Approach

class Solution {
    public int maxProfit(int[] prices) {
        // Start from day 0, Initially, we do not hold any stock, so holdStock = false
        return maxProfit(0, false, prices);
    }

    private int maxProfit(int day, boolean holdStock, int[] prices) {
        if (day == prices.length) {
            return 0;
        }

        // Case 1: We do NOT currently hold a stock → We can either buy or skip buying
        if (!holdStock) {
            // Option 1: Buy stock today → Deduct price of current day from profit and switch to holdStock=true
            int buy = -prices[day] + maxProfit(day + 1, true, prices);
            // Option 2: Skip buying today → Move to next day without holding any stock
            int skipBuy = maxProfit(day + 1, false, prices);
            // Take the maximum of buying or skipping
            return Math.max(buy, skipBuy);
        }

        // Case 2: We currently HOLD a stock → We can either sell or skip selling

        // Option 1: Sell stock today → Add today's price to profit and switch to holdStock=false
        int sell = prices[day] + maxProfit(day + 1, false, prices);
        // Option 2: Skip selling today → Continue to next day still holding the stock
        int skipSell = maxProfit(day + 1, true, prices);

        // Take the maximum of selling or skipping
        return Math.max(sell, skipSell);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[day][holdStock] stores the maximum profit that can be achieved
    * starting from the given day with the current holding state.
    *
    * Meaning of values:
    * - null  → this state has NOT been computed yet
    * - value → maximum profit achievable for this state
    *
    * State definition:
    * - holdStock = 0 → we do NOT hold a stock (can choose to buy or skip)
    * - holdStock = 1 → we currently hold a stock (can choose to sell or skip)
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int maxProfit(int[] prices) {
        dp = new Integer[prices.length][2];
        return maxProfit(0, 0, prices);
    }

    private int maxProfit(int day, int holdStock, int[] prices) {
        if (day == prices.length) {
            return 0;
        }

        if (dp[day][holdStock] != null) {
            return dp[day][holdStock];
        }

        if (holdStock == 0) {
            int buy = -prices[day] + maxProfit(day + 1, 1, prices);
            int skipBuy = maxProfit(day + 1, 0, prices);
            return dp[day][holdStock] = Math.max(buy, skipBuy);
        }

        int sell = prices[day] + maxProfit(day + 1, 0, prices);
        int skipSell = maxProfit(day + 1, 1, prices);

        return dp[day][holdStock] = Math.max(sell, skipSell);
    }
}


//Optimal Approach

//Naive implementation

class Solution {
    public int maxProfit(int[] prices) {
        /*
        * dp[day][holdStock] represents:
        * "Maximum profit that can be achieved starting from the given day
        * with the current holding state."
        *
        * State meaning:
        * - holdStock = 0 → we do NOT hold a stock (we can buy or skip)
        * - holdStock = 1 → we currently hold a stock (we can sell or skip)
        */
        int[][] dp = new int[prices.length + 1][2];

        dp[prices.length][0] = dp[prices.length][1] = 0;

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int holdStock = 0; holdStock <= 1; holdStock++) {
                int profit = 0;
                if (holdStock == 0) {
                    int buy = -prices[day] + dp[day + 1][1];
                    int skipBuy = dp[day + 1][0];
                    profit = Math.max(buy, skipBuy);
                } else {
                    int sell = prices[day] + dp[day + 1][0];
                    int skipSell = dp[day + 1][1];
                    profit = Math.max(sell, skipSell);
                }
                dp[day][holdStock] = profit;
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int maxProfit(int[] prices) {
        int[] currentRow = new int[2];
        int[] nextRow = new int[2];

        nextRow[0] = nextRow[1] = 0;

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int holdStock = 0; holdStock <= 1; holdStock++) {
                int profit = 0;
                if (holdStock == 0) {
                    int buy = -prices[day] + nextRow[1];
                    int skipBuy = nextRow[0];
                    profit = Math.max(buy, skipBuy);
                } else {
                    int sell = prices[day] + nextRow[0];
                    int skipSell = nextRow[1];
                    profit = Math.max(sell, skipSell);
                }
                currentRow[holdStock] = profit;
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}
