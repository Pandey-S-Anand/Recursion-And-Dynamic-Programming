//Bruteforce approach

class Solution {
    // Store the elements of the largest divisible subset found
    private List<Integer> bestSubset;

    public List<Integer> largestDivisibleSubset(int[] arr) {
        generateLargestDivisibleSubset(arr, 0, new ArrayList<>());
        return bestSubset;
    }

    private void generateLargestDivisibleSubset(int[] arr, int index, List<Integer> currentSubset) {
        // Base case: all elements processed
        if (index == arr.length) {
            if (isDivisibleSubset(currentSubset) && (bestSubset == null || currentSubset.size() > bestSubset.size())) {
                bestSubset = new ArrayList<>(currentSubset);
            }
            return;
        }

        //Include the current element
        currentSubset.add(arr[index]);
        generateLargestDivisibleSubset(arr, index + 1, currentSubset);
        // Backtrack (remove last element)
        currentSubset.remove(currentSubset.size() - 1);
        //Exclude the current element
        generateLargestDivisibleSubset(arr, index + 1, currentSubset);
    }

    /*
     * This method checks if a subset is a valid divisible subset.
     * A subset is valid if every pair of elements (i, j) within it satisfies
     * either subset[i] % subset[j] == 0 or subset[j] % subset[i] == 0.
     */
    private boolean isDivisibleSubset(List<Integer> subset) {
        for (int i = 0; i < subset.size(); i++) {
            for (int j = i + 1; j < subset.size(); j++) {
                if ((subset.get(j) % subset.get(i)) != 0 && (subset.get(i) % subset.get(j)) != 0) {
                    return false; // Return false if any pair fails the divisibility check
                }
            }
        }

        return true; // Return true if all pairs satisfy divisibility conditions
    }
}



//Better Approach

/*
Sorting plays a crucial role in ensuring that divisibility is maintained among elements of any particular subset:

For any indices i < j, if `arr[j]` is divisible by an earlier element `arr[i]`, 
then all factors of `arr[i]` that appear before it in the sorted array will also divide `arr[j]`. 
This order allows us to only check divisibility between consecutive elements in the sorted order,
rather than needing to verify divisibility between all pairs in a subset.

Example:
    arr: {2, 4, 8, 16, 32}
    Since 32 is divisible by 16, it will also be divisible by 8, 4, and 2 due to the sorted order.

Note: A subset doesn't necessarily need to maintain the original order of appearance from the input array.
      Any subset can be arranged in multiple configurations; however, one such configuration will form a subsequence.
      Therefore, the problem can be thought of as finding the longest divisible subsequence.
          
This means we are effectively searching for the longest divisible subsequence of elements in the sorted array.
*/

class Solution {
    private List<Integer> bestSubset;

    public List<Integer> largestDivisibleSubset(int[] arr) {
        Arrays.sort(arr);
        generateLargestDivisibleSubset(arr, 0, -1, new ArrayList<>());
        return bestSubset;
    }

    private void generateLargestDivisibleSubset(int[] arr, int index, int lastIncludedIndex, List<Integer> currentSubset) {
        if (index == arr.length) {
            if (bestSubset == null || currentSubset.size() > bestSubset.size()) {
                bestSubset = new ArrayList<>(currentSubset);
            }
            return;
        }

        /*
        * Include arr[index] in the subset if it's divisible by the last included element.
        * lastIncludedIndex == -1 condition allows us to add the first element without any divisibility check.
        */
        if (lastIncludedIndex == -1 || arr[index] % arr[lastIncludedIndex] == 0) {
            currentSubset.add(arr[index]);
            generateLargestDivisibleSubset(arr, index + 1, index, currentSubset);
            currentSubset.remove(currentSubset.size() - 1);
        }

        // Exclude arr[index] and move to the next element.
        generateLargestDivisibleSubset(arr, index + 1, lastIncludedIndex, currentSubset);
    }
}



//Optimal Approach

/*
   The following approach is used to find the Longest Divisible Subsequence (LDS) 
   in an array by computing the LDS ending at each index:

   Approach:

   1. Subsequence Ending at Each Index:
      Every divisible subsequence in the array must end at some index `i`. 
      Therefore, we focus on calculating the length of the LDS that ends at each index `i`.
      Once we determine the LDS length for each ending index, the overall longest divisible 
      subsequence in the array will be the maximum among these values.

   2. Finding Potential LDS Candidates:
      For each element `arr[i]`, we examine all previous elements `arr[j]` (where `j < i`).
      If `arr[i]` is divisible by `arr[j]`, then `arr[i]` can extend the divisible subsequence 
      that ends at `arr[j]`.

   3. Updating the LDS Length for Each Index `i`:
      - For each valid candidate `arr[j]`, we retrieve the LDS ending at `j` (stored in `dp[j]`).
      - Among all such candidates, the longest divisible subsequence ending at `j` provides 
        the maximum length that `arr[i]` can extend.
      - We then add 1 to this length to include the current element `arr[i]`, giving us 
        the LDS length ending at `i`.

   4. Final Step:
      After computing the LDS for each index, the overall longest divisible subsequence 
      in the array is the maximum value in the `dp` array.
*/
class Solution {
    public List<Integer> largestDivisibleSubset(int[] arr) {
        Arrays.sort(arr);

        int maxLengthLDS = 0;
        int ldsEndIndex = 0; // 'ldsEndIndex' points to the last element of the LIS (i.e., where LIS ends)

        // dp[i] → Length of the longest divisible subsequence ending at index i
        int[] dp = new int[arr.length];
        /*
        prevIndex[i] → Stores the index of the previous element in the LDS 
        ending at index i (i.e., the element chosen just before arr[i] in that subsequence)  
        */
        int[] prevIndex = new int[arr.length];

        for (int i = 0; i < arr.length; i++) {
            int bestPrevLDSLength = 0;
            int bestPrevLDSIdx = -1;

            for (int j = 0; j < i; j++) {
                if (arr[i] % arr[j] == 0 && dp[j] > bestPrevLDSLength) {
                    bestPrevLDSLength = dp[j];
                    bestPrevLDSIdx = j;
                }
            }

            dp[i] = bestPrevLDSLength + 1;
            prevIndex[i] = bestPrevLDSIdx;

            if (dp[i] > maxLengthLDS) {
                maxLengthLDS = dp[i];
                ldsEndIndex = i;
            }
        }

        List<Integer> lds = new ArrayList<>();

        /*
        * We backtrack the LDS (largest divisible subset) in reverse using the parent pointers:
        *
        * previousIndex[i] tells us:
        * "which element came just before arr[i] in the LDS"
        *
        * So we keep moving:
        * current index → its previous index → its previous → ...
        * until we reach -1 (start of subsequence)
        */
        int idx = ldsEndIndex;

        while (prevIndex[idx] != -1) {
            lds.add(arr[idx]);
            idx = prevIndex[idx];
        }

        /*
        * At this point, 'idx' is the starting element of the LDS
        * (its previousIndex is -1), so we add it as well.
        */
        lds.add(arr[idx]);

        /*
        * The elements were collected while backtracking from end → start of the LDS.
        * Hence, the list is currently in reverse order.
        *
        * We reverse it to restore the correct sequence (start → end of LDS).
        */
        Collections.sort(lds);

        return lds;
    }
}
