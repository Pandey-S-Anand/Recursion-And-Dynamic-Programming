//Naive implementation

class Solution {
    public int numberOfWays(int n) {
        if (n == 1) {
            return 1;
        }

        // dp[breadth] represents the number of ways to tile a 2 × breadth board using 2 × 1 tiles.
        int[] dp = new int[n + 1];

        dp[1] = 1;
        dp[2] = 2;

        for (int breadth = 3; breadth <= n; breadth++) {
            dp[breadth] = dp[breadth - 1] + dp[breadth - 2];
        }

        return dp[n];
    }
}


//Optimal implementation

class Solution {
    public int numberOfWays(int n) {
        if (n == 1) {
            return 1;
        }

        int waysForPrevPrevWidth = 1;
        int waysForPrevWidth = 2;

        for (int breadth = 3; breadth <= n; breadth++) {
            int currentWidth = waysForPrevWidth + waysForPrevPrevWidth;
            waysForPrevPrevWidth = waysForPrevWidth;
            waysForPrevWidth = currentWidth;
        }

        return waysForPrevWidth;
    }
}
