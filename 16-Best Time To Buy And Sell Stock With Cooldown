//Naive implementation

class Solution {
    /*
    * dp[day][holdStock] represents:
    * "Maximum profit that can be achieved from day 'day' to the end,
    * given the current holding state, considering the cooldown constraint."
    *
    * State meaning:
    * - holdStock = 0 → we do NOT hold a stock (can buy or skip)
    * - holdStock = 1 → we currently hold a stock (can sell or skip)
    *
    * Cooldown rule:
    * - After selling a stock, we must skip the next day,
    *   so we move to day + 2 after a sell operation.
    */
    public int maxProfit(int[] prices) {
        int[][] dp = new int[prices.length + 2][2];

        dp[prices.length][0] = dp[prices.length][1] = 0;
        dp[prices.length + 1][0] = dp[prices.length + 1][1] = 0;

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int holdStock = 0; holdStock <= 1; holdStock++) {
                int profit = 0;

                if (holdStock == 0) {
                    int buy = -prices[day] + dp[day + 1][1];
                    int skipBuy = dp[day + 1][0];
                    profit = Math.max(buy, skipBuy);
                } else {
                    int sell = prices[day] + dp[day + 2][0];
                    int skipSell = dp[day + 1][1];
                    profit = Math.max(sell, skipSell);
                }

                dp[day][holdStock] = profit;
            }
        }

        return dp[0][0];
    }
}


//Better implementation

class Solution {
    public int maxProfit(int[] prices) {
        int[][] dp = new int[prices.length + 2][2];

        for (int day = prices.length - 1; day >= 0; day--) {
            int buy = -prices[day] + dp[day + 1][1];
            int skipBuy = dp[day + 1][0];
            dp[day][0] = Math.max(buy, skipBuy);

            int sell = prices[day] + dp[day + 2][0];
            int skipSell = dp[day + 1][1];
            dp[day][1] = Math.max(sell, skipSell);
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int maxProfit(int[] prices) {
        // Since dp[day][*] depends on dp[day + 1][*] and dp[day + 2][*] , we use three arrays (currentRow, nextRow, rowAfterNext) instead of a full DP table
        int[] currentRow = new int[2];
        int[] nextRow = new int[2];
        int[] rowAfterNext = new int[2];

        nextRow[0] = nextRow[1] = rowAfterNext[0] = rowAfterNext[1] = 0;

        for (int day = prices.length - 1; day >= 0; day--) {
            int buy = -prices[day] + nextRow[1];
            int skipBuy = nextRow[0];
            currentRow[0] = Math.max(buy, skipBuy);

            int sell = prices[day] + rowAfterNext[0];
            int skipSell = nextRow[1];
            currentRow[1] = Math.max(sell, skipSell);

            int[] temp = rowAfterNext;
            rowAfterNext = nextRow;
            nextRow = currentRow;
            currentRow = temp;
        }

        return nextRow[0];
    }
}
