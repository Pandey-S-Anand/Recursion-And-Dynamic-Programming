/*
 * Intuition:
 *
 * - We iterate over every cell in the matrix.
 * - For each cell that contains 1, we treat it as the top-left corner
 *   of a square submatrix and try to find the largest square (all 1s)
 *   that can be formed starting from that cell.
 *
 * - The value returned by countSquares(row, col) represents:
 *     → the size of the largest square submatrix (with all 1s)
 *       having (row, col) as its top-left corner.
 *
 * - This size also directly gives the number of valid square submatrices
 *   starting at that cell.
 *
 *   Example:
 *   If the largest square size is 3, then we can form:
 *     → 1 square of size 1
 *     → 1 square of size 2
 *     → 1 square of size 3
 *
 *   So total = 3 squares from this cell.
 *
 * ---------------------------------------------------------------
 *
 * Why do we explore right, bottom, and diagonal?
 *
 * - A single cell with value 1 itself forms a square of size 1.
 *
 * - To expand this into a square of size 2 (with current cell as top-left),
 *   we must ensure:
 *
 *     → the cell to the right is 1
 *     → the cell below is 1
 *     → the diagonal cell (bottom-right) is 1
 *
 * - These three directions ensure that a full square can be formed.
 *
 * - For larger squares, the same idea extends recursively:
 *   we depend on the smallest square possible among:
 *
 *     → right
 *     → bottom
 *     → diagonal
 *
 * - So the recurrence becomes:
 *
 *     size = 1 + min(right, bottom, diagonal)
 */

//Bruteforce Approach

class Solution {
    public int countSquares(int[][] matrix) {
        int totalSquares = 0;

        for (int row = 0; row < matrix.length; row++) {
            for (int col = 0; col < matrix[0].length; col++) {
                if (matrix[row][col] == 1) {
                    totalSquares += maxSquareSizeFromCell(matrix, row, col);
                }
            }
        }
        return totalSquares;
    }

    private int maxSquareSizeFromCell(int[][] matrix, int row, int col) {
        if (row == matrix.length || col == matrix[0].length) {
            return 0;
        }

        if (matrix[row][col] == 0) {
            return 0;
        }

        int rightSquareSize = maxSquareSizeFromCell(matrix, row, col + 1);
        int downSquareSize = maxSquareSizeFromCell(matrix, row + 1, col);
        int diagonalSquareSize = maxSquareSizeFromCell(matrix, row + 1, col + 1);

        return 1 + Math.min(rightSquareSize, Math.min(downSquareSize, diagonalSquareSize));
    }
}


//Better Approach

class Solution {
    /*
     * Memoization:
     * dp[row][col] represents the maximum size of a square submatrix (all 1s)
     * where (row, col) acts as the top-left corner of the square.
     *
     * Important:
     * - This value also tells how many square submatrices have
     *   (row, col) as their top-left corner:
     *     → sizes: 1, 2, ..., k
     *     → total = k squares
     *
     * Meaning of values:
     * - null  → this state has NOT been computed yet
     * - value → maximum square size with (row, col) as top-left corner
     *
     * If dp[row][col] is already computed, return it.
     * Otherwise, compute and store it to avoid recomputing
     * overlapping subproblems.
     */
    private Integer[][] dp;

    public int countSquares(int[][] matrix) {
        dp = new Integer[matrix.length][matrix[0].length];
        int totalSquares = 0;

        for (int row = 0; row < matrix.length; row++) {
            for (int col = 0; col < matrix[0].length; col++) {
                if (matrix[row][col] == 1) {
                    totalSquares += maxSquareSizeFromCell(matrix, row, col);
                }
            }
        }

        return totalSquares;
    }

    private int maxSquareSizeFromCell(int[][] matrix, int row, int col) {
        if (row == matrix.length || col == matrix[0].length) {
            return 0;
        }

        if (matrix[row][col] == 0) {
            return 0;
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int rightSquareSize = maxSquareSizeFromCell(matrix, row, col + 1);
        int downSquareSize = maxSquareSizeFromCell(matrix, row + 1, col);
        int diagonalSquareSize = maxSquareSizeFromCell(matrix, row + 1, col + 1);

        return dp[row][col] = 1 + Math.min(rightSquareSize, Math.min(downSquareSize, diagonalSquareSize));
    }
}


