/**
 * We are given an array of non-negative integers and asked to assign either a '+' or '-'
 * sign to each number such that the final evaluated sum equals the given targetSum.
 *
 * Let totalSum = sum(arr) → This is the maximum sum we can achieve if all elements are assigned '+'.
 * The minimum sum is -totalSum → if all elements are assigned '-'.
 *
 * Therefore, the range of valid targetSum values lies within:
 *      targetSum ∈ [-totalSum, totalSum]
 *
 * ------------------------------------------------------------
 * Why do we check: Math.abs(targetSum) > totalSum
 *
 * If the absolute value of targetSum exceeds totalSum, then:
 *
 * 1. Case: targetSum < -totalSum
 *    → Even if we assign '+' to every element, we cannot increase the sum enough.
 *    → It is impossible to reach such a target.
 *
 * 2. Case: targetSum > totalSum
 *    → Even if we assign '-' to every element, we cannot reduce the sum enough.
 *    → Hence, it is impossible to reach such a target.
 *
 * Therefore, when |targetSum| > totalSum, we return 0 directly,
 * as no valid assignment of signs can achieve the target.
 *
 * ------------------------------------------------------------
 * Why do we apply an offset to targetSum in memoization?
 *
 * Since targetSum can be negative, we cannot directly use it as an index
 * in the dp table, because array indices must be non-negative.
 *
 * To handle this, we shift the entire range using an offset:
 *      offset = totalSum
 *
 * Now the range:
 *      [-totalSum, totalSum] → [0, 2 * totalSum]
 *
 * Any targetSum 't' is stored as:
 *      dp[index][t + offset]
 *
 * This ensures:
 * - No negative indices
 * - Full coverage of all possible sums
 */
class Solution {
    // dp[index][sum] represents the number of ways to reach the sum (sum - offset)  using elements from index 'index' to end of the array.
    private Integer[][] dp;

    public int findTargetSumWays(int[] arr, int targetSum) {
        // Step 1: Calculate total sum of array elements
        int arrSum = Arrays.stream(arr).sum();

        dp = new Integer[arr.length][(2 * arrSum) + 1]; // size = n x ((2 * arrSum) + 1))

        return findTargetSumWays(arr, 0, targetSum, arrSum);
    }

    private int findTargetSumWays(int[] arr, int index, int targetSum, int offset) {
        /* 
         Pruning: If current targetSum is outside the valid range [-offset, +offset],
         there's no way to achieve it (i.e reduce it to zero) by adding or subtracting future elements
         */
        if (Math.abs(targetSum) > offset) {
            return 0;
        }

        if (index == arr.length) {
            return targetSum == 0 ? 1 : 0;
        }

        if (dp[index][targetSum + offset] != null) {
            return dp[index][targetSum + offset];
        }

        int waysWithPositiveSign = findTargetSumWays(arr, index + 1, targetSum - arr[index], offset);
        int waysWithNegativeSign = findTargetSumWays(arr, index + 1, targetSum + arr[index], offset);

        return dp[index][targetSum + offset] = waysWithPositiveSign + waysWithNegativeSign;
    }
}


