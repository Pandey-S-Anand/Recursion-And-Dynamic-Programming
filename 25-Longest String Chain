//Naive implementation

class Solution {
    public int longestStrChain(String[] words) {
        /*
        * DP State Definition:
        *
        * dp[index][lastIncludedIndex + 1] represents the maximum length of the longest
        * string chain that can be formed starting from the current index,
        * given that the last included word in the chain is at lastIncludedIndex.
        *
        * Why (lastIncludedIndex + 1)?
        * - lastIncludedIndex can be -1 (no word chosen yet)
        * - Array indices cannot be negative
        * - So we shift it by +1 to map:
        *      -1 -> 0
        *       0 -> 1
        *       1 -> 2
        *       ...
        *
        * Meaning:
        * - dp[i][j] stores the best possible chain length starting from index i,
        *   where the previous chosen word index is (j - 1).
        *
        * Final Answer:
        * - dp[0][0] represents starting from index 0 with no previously chosen word.
        */
        int[][] dp = new int[words.length + 1][words.length + 1];

        Arrays.sort(words, (word1, word2) -> {
            return Integer.compare(word1.length(), word2.length());
        });

        for (int i = words.length - 1; i >= 0; i--) {
            for (int lastIncludedIndex = words.length - 1; lastIncludedIndex >= -1; lastIncludedIndex--) {
                int include = 0;

                if (lastIncludedIndex == -1 || isValidChain(words[lastIncludedIndex], words[i])) {
                    include = 1 + dp[i + 1][i + 1];
                }

                int exclude = dp[i + 1][lastIncludedIndex + 1];

                dp[i][lastIncludedIndex + 1] = Math.max(include, exclude);
            }
        }

        return dp[0][0];
    }

    private boolean isValidChain(String prevWord, String currentWord) {
        if (currentWord.length() - prevWord.length() == 1 && isSubsequence(prevWord, currentWord)) {
            return true;
        }

        return false;
    }

    private boolean isSubsequence(String prevWord, String currentWord) {
        int i = 0, j = 0;

        while (i < prevWord.length() && j < currentWord.length()) {
            if (prevWord.length() - i > currentWord.length() - j) {
                return false;
            }

            if (prevWord.charAt(i) == currentWord.charAt(j)) {
                i++;
            }
            j++;
        }

        return i == prevWord.length();
    }
}


//Optimal implementation

class Solution {
    public int longestStrChain(String[] words) {
        /*
        * Space Optimization (from 2D DP to 1D):
        *
        * In the tabulation approach, dp[index][lastIncludedIndex + 1] depends only on
        * the next row i.e., dp[index + 1][...].
        *
        * Since each state only relies on the next index, we do not need to maintain
        * the entire 2D DP table. Instead, we can optimize space by keeping only:
        *
        * - nextRow    -> represents dp[index + 1][...]
        * - currentRow -> represents dp[index][...]
        *
        * After computing currentRow, we shift it to nextRow for the next iteration.
        */
        int[] currentRow = new int[words.length + 1];
        int[] nextRow = new int[words.length + 1];

        Arrays.sort(words, (word1, word2) -> {
            return Integer.compare(word1.length(), word2.length());
        });

        for (int i = words.length - 1; i >= 0; i--) {
            for (int lastIncludedIndex = words.length - 1; lastIncludedIndex >= -1; lastIncludedIndex--) {
                int include = 0;

                if (lastIncludedIndex == -1 || isValidChain(words[lastIncludedIndex], words[i])) {
                    include = 1 + nextRow[i + 1];
                }

                int exclude = nextRow[lastIncludedIndex + 1];

                currentRow[lastIncludedIndex + 1] = Math.max(include, exclude);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }

    private boolean isValidChain(String prevWord, String currentWord) {
        if (currentWord.length() - prevWord.length() == 1 && isSubsequence(prevWord, currentWord)) {
            return true;
        }

        return false;
    }

    private boolean isSubsequence(String prevWord, String currentWord) {
        int i = 0, j = 0;

        while (i < prevWord.length() && j < currentWord.length()) {
            if (prevWord.length() - i > currentWord.length() - j) {
                return false;
            }

            if (prevWord.charAt(i) == currentWord.charAt(j)) {
                i++;
            }
            j++;
        }

        return i == prevWord.length();
    }
}


//Optimal Approach

/*
 * Sorting the words by length ensures that each word’s potential predecessors (which are shorter) 
 * are processed before the word itself, enabling us to build chains progressively.
 * 
 * The key insight is that adding a single character to a word (wordA) to form another word (wordB), 
 * where wordA is a valid predecessor of wordB, is equivalent to removing one character from wordB 
 * to obtain wordA.
 *
 * Approach:
 * By treating each word as a potential endpoint of the longest chain, we calculate its possible predecessors 
 * by removing one character at a time.
 *
 * For each predecessor generated, we check if it exists in the dp map. If it does, it means the predecessor 
 * has a chain length (retrieved from `dp.get(predecessor)`) that can extend to the current word. We then compare 
 * the chain lengths of all predecessors and select the longest one. Finally, we append the current word to that 
 * chain, increasing its length by one.
 *
 * After processing all predecessors, we update the maximum chain length (`maxChainLength`) with the longest chain 
 * found across all words.
 */

//Naive implementation

class Solution {
    public int longestStrChain(String[] words) {
        // Sort words by length to ensure that predecessors are processed before longer words because the predecessor's length is always 1 less than the current word length
        Arrays.sort(words, (word1, word2) -> Integer.compare(word1.length(), word2.length()));

        int maxChainLength = 0;
        // Map to store the maximum chain length ending with each word
        Map<String, Integer> longestChainEndingAt = new HashMap<>();

        for (String word : words) {
            int bestPrevChainLength = 0; // Track predecessor of the current word which is forming the longest chain

            // Generate all possible predecessor by removing one character at a time from the current word
            for (int i = 0; i < word.length(); i++) {
                String predecessor = word.substring(0, i) + word.substring(i + 1);

                // Check if the predecessor exists and update the max chain length accordingly
                if (longestChainEndingAt.containsKey(predecessor)) {
                    bestPrevChainLength = Math.max(bestPrevChainLength, longestChainEndingAt.get(predecessor));
                }
            }
            
            int currentChainLength = bestPrevChainLength + 1;

            // The current word’s chain length is max. length chain from predecessor + 1
            longestChainEndingAt.put(word, currentChainLength);
            // Update the overall longest chain length found so far
            maxChainLength = Math.max(maxChainLength, currentChainLength);
        }

        // Return the longest chain length found across all words
        return maxChainLength;
    }
}


//Optimal Implementation

class Solution {
    public int longestStrChain(String[] words) {
        Arrays.sort(words, (word1, word2) -> Integer.compare(word1.length(), word2.length()));

        int maxChainLength = 0;
        Map<String, Integer> longestChainEndingAt = new HashMap<>();

        for (String word : words) {
            int bestPrevChainLength = 0;
            StringBuilder wordCopy = new StringBuilder(word);

            for (int i = 0; i < word.length(); i++) {
                char deletedChar = wordCopy.charAt(i);
                wordCopy.deleteCharAt(i);
                String predecessor = wordCopy.toString();

                if (longestChainEndingAt.containsKey(predecessor)) {
                    bestPrevChainLength = Math.max(bestPrevChainLength, longestChainEndingAt.get(predecessor));
                }

                wordCopy.insert(i, deletedChar);
            }

            int currentChainLength = bestPrevChainLength + 1;
            longestChainEndingAt.put(word, currentChainLength);

            maxChainLength = Math.max(maxChainLength, currentChainLength);
        }

        return maxChainLength;
    }
}
