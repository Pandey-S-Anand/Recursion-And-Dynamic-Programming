//Bruteforce approach

class Solution {
    /*
      The key idea behind solving the Longest String Chain problem is that each subsequent word 
      in the chain must be exactly one character longer and should contain the previous word 
      as a subsequence.
    
      To ensure this order, we first sort the array based on word length. 
      This guarantees that shorter words are processed before longer ones, and words with 
      similar lengths are grouped together.
    */
    public int longestStrChain(String[] words) {
        Arrays.sort(words, (word1, word2) -> {
            return Integer.compare(word1.length(), word2.length());
        });

        return longestStrChain(words, 0, -1);
    }

    private int longestStrChain(String[] words, int index, int lastIncludedIndex) {
        if (index == words.length) {
            return 0;
        }

        int include = 0;
        /*
        * If lastIncludedIndex is -1 (meaning no word has been included yet), it
        * indicates that we can start a chain with any word from the array.
        * Alternatively, if the current word can form a valid chain with the word at
        * lastIncludedIndex (i.e., the previous word in the chain), we consider
        * including the current word in the chain.
        */
        if (lastIncludedIndex == -1 || isValidChain(words[lastIncludedIndex], words[index])) {
            include = 1 + longestStrChain(words, index + 1, index);
        }

        // Exclude the current word and move on to the next word
        int exclude = longestStrChain(words, index + 1, lastIncludedIndex);

        // Return the maximum length from including or excluding the current word
        return Math.max(include, exclude);
    }

    private boolean isValidChain(String prevWord, String currentWord) {
        /*
        * Valid chain condition: The length of the next word in the chain must be
        * exactly 1 greater than the length of the previous word, and the previous word
        * must be a subsequence of the next word.
        */
        if (currentWord.length() - prevWord.length() == 1 && isSubsequence(prevWord, currentWord)) {
            return true;
        }

        return false;
    }

    private boolean isSubsequence(String prevWord, String currentWord) {
        int i = 0, j = 0;

        while (i < prevWord.length() && j < currentWord.length()) {
            // Early exit: if remaining characters in prevWord exceed remaining in currentWord
            if (prevWord.length() - i > currentWord.length() - j) {
                return false;
            }

            if (prevWord.charAt(i) == currentWord.charAt(j)) {
                i++;
            }
            j++;
        }

        // If we've traversed all characters in prevWord, it means it's a subsequence of currentWord
        return i == prevWord.length();
    }
}



//Good Approach

class Solution {
    /*
    * Memoization:
    * dp[index][lastIncludedIdx + 1] stores the maximum length of the longest string chain
    * that can be formed starting from the given index,
    * given the index of the last included word.
    *
    * Why (lastIncludedIdx + 1)?
    * - lastIncludedIdx can be -1 (no word chosen yet)
    * - Array indices cannot be negative
    * - So we shift it by +1 to map:
    *      -1 -> 0
    *       0 -> 1
    *       1 -> 2
    *       ...
    *
    * Meaning of values:
    * - null  -> this state has NOT been computed yet
    * - value -> maximum chain length for this state
    *
    * State definition:
    * - index             -> current index in the array
    * - lastIncludedIdx   -> index of the last word included in the chain
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp to avoid recomputation
    * of overlapping subproblems.
    */
    private Integer[][] dp;

    public int longestStrChain(String[] words) {
        dp = new Integer[words.length][words.length + 1];
        Arrays.sort(words, (word1, word2) -> {
            return Integer.compare(word1.length(), word2.length());
        });

        return longestStrChain(words, 0, -1);
    }

    private int longestStrChain(String[] words, int index, int lastIncludedIndex) {
        if (index == words.length) {
            return 0;
        }

        if (dp[index][lastIncludedIndex + 1] != null) {
            return dp[index][lastIncludedIndex + 1];
        }

        int include = 0;

        if (lastIncludedIndex == -1 || isValidChain(words[lastIncludedIndex], words[index])) {
            include = 1 + longestStrChain(words, index + 1, index);
        }

        int exclude = longestStrChain(words, index + 1, lastIncludedIndex);

        return dp[index][lastIncludedIndex + 1] = Math.max(include, exclude);
    }

    private boolean isValidChain(String prevWord, String currentWord) {
        if (currentWord.length() - prevWord.length() == 1 && isSubsequence(prevWord, currentWord)) {
            return true;
        }

        return false;
    }

    private boolean isSubsequence(String prevWord, String currentWord) {
        int i = 0, j = 0;

        while (i < prevWord.length() && j < currentWord.length()) {
            if (prevWord.length() - i > currentWord.length() - j) {
                return false;
            }

            if (prevWord.charAt(i) == currentWord.charAt(j)) {
                i++;
            }
            j++;
        }

        return i == prevWord.length();
    }
}


