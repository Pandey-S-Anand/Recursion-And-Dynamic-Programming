//Bruteforce Approach

class Solution {
    public int findNumberOfLIS(int[] arr) {
        return findLengthAndCountOfLIS(arr, 0, -1)[1]; // The second element in the result array holds the count of LIS
    }

    private int[] findLengthAndCountOfLIS(int[] arr, int index, int lastIncludedIdx) {
        /* 
          Base case: Once all elements have been processed (i.e., the array is exhausted),
          the LIS length is 0, and there is only one way to form the empty subsequence. 
        */
        if (index == arr.length) {
            return new int[] { 0, 1 };
        }

        int[] includeResult = new int[2];
        // Option 1: Include the current element, if it's larger than the last included element
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] < arr[index]) {
            int[] nextResult = findLengthAndCountOfLIS(arr, index + 1, index);
            /*
             * countAndLengthOfLIS(arr, currentIndex + 1, currentIndex) is returning two things:
             * 
             * nextResult[0]=The length of the LIS , starting from the current index onward. i.e from current index + 1
             * nextResult[1]=The number of such subsequences (of length nextResult[0])
             */
            includeResult[0] = 1 + nextResult[0];
            includeResult[1] = nextResult[1];
            /*
             * includeResult[0]= The length of the LIS starting from currentIndex will be 1 + nextResult[0], 
             * because we are adding the element arr[currentIndex] to the subsequences formed from currentIndex + 1. 
             * This increases the length by 1 compared to what we would get starting from currentIndex + 1.
             * 
             * includeResult[1]=The number of such subsequences (i.e of length  includeResult[0]) = nextResult[1]
             * It is the same as the count of subsequences that start from currentIndex + 1, i.e., nextResult[1], 
             * because the subsequences formed by including arr[currentIndex] will be the same as the ones formed 
             * by the subsequences from currentIndex + 1 — we're simply adding arr[currentIndex] to them.
             */
        }

        // Option 2: Exclude the current element
        int[] excludeResult = findLengthAndCountOfLIS(arr, index + 1, lastIncludedIdx);
        int[] result = new int[2]; // {LIS length, count}

        if (includeResult[0] > excludeResult[0]) {
            result[0] = includeResult[0];
            result[1] = includeResult[1];
        } else if (excludeResult[0] > includeResult[0]) {
            result[0] = excludeResult[0];
            result[1] = excludeResult[1];
        } else { // Both include and exclude give the same LIS length
            result[0] = includeResult[0];
            result[1] = includeResult[1] + excludeResult[1];
        }

        return result;
    }
}



//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[(index, lastIncludedIdx)] stores {max LIS length, count of such LIS}
    * starting from this state.
    *
    * If already computed, return it.
    */
    private Map<String, int[]> dp;

    public int findNumberOfLIS(int[] arr) {
        dp = new HashMap<>();
        return findLengthAndCountOfLIS(arr, 0, -1)[1];
    }

    private int[] findLengthAndCountOfLIS(int[] arr, int index, int lastIncludedIdx) {
        if (index == arr.length) {
            return new int[] { 0, 1 };
        }

        String key = index + "" + lastIncludedIdx;
        if (dp.containsKey(key)) {
            return dp.get(key);
        }

        int[] includeResult = new int[2];
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] < arr[index]) {
            int[] nextResult = findLengthAndCountOfLIS(arr, index + 1, index);

            includeResult[0] = 1 + nextResult[0];
            includeResult[1] = nextResult[1];
        }

        int[] excludeResult = findLengthAndCountOfLIS(arr, index + 1, lastIncludedIdx);
        int[] result = new int[2];
        if (includeResult[0] > excludeResult[0]) {
            result[0] = includeResult[0];
            result[1] = includeResult[1];
        } else if (excludeResult[0] > includeResult[0]) {
            result[0] = excludeResult[0];
            result[1] = excludeResult[1];
        } else {
            result[0] = includeResult[0];
            result[1] = includeResult[1] + excludeResult[1];
        }

        dp.put(key, result);

        return result;
    }
}


//Optimal approach

//Intuitive implementation

class Solution {
    public int findNumberOfLIS(int[] arr) {
        /*
         * DP State:
         *
         * dp[i][lastIncludedIdx + 1] →
         * Maximum length of LIS that can be formed starting from index i,
         * given the last included element index (lastIncludedIdx).
         *
         * count[i][lastIncludedIdx + 1] →
         * Number of subsequences that achieve the maximum length
         * stored in dp[i][lastIncludedIdx + 1] for this state.
         *
         * Why (lastIncludedIdx + 1)?
         * - lastIncludedIdx can be -1 (no element chosen yet)
         * - To avoid negative indexing, we shift it by +1:
         *     -1 → 0, 0 → 1, 1 → 2, ...
         */
        int[][] dp = new int[arr.length + 1][arr.length + 1];
        int[][] count = new int[arr.length + 1][arr.length + 1];

        for (int lastIncludedIdx = -1; lastIncludedIdx < arr.length; lastIncludedIdx++) {
            dp[arr.length][lastIncludedIdx + 1] = 0;
            count[arr.length][lastIncludedIdx + 1] = 1;
        }

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int[] includeResult = new int[2];

                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] < arr[i]) {
                    includeResult[0] = 1 + dp[i + 1][i + 1];
                    includeResult[1] = count[i + 1][i + 1];
                }

                int[] excludeResult = new int[2];

                excludeResult[0] = dp[i + 1][lastIncludedIdx + 1];
                excludeResult[1] = count[i + 1][lastIncludedIdx + 1];

                if (includeResult[0] > excludeResult[0]) {
                    dp[i][lastIncludedIdx + 1] = includeResult[0];
                    count[i][lastIncludedIdx + 1] = includeResult[1];
                } else if (excludeResult[0] > includeResult[0]) {
                    dp[i][lastIncludedIdx + 1] = excludeResult[0];
                    count[i][lastIncludedIdx + 1] = excludeResult[1];
                } else {
                    dp[i][lastIncludedIdx + 1] = includeResult[0];
                    count[i][lastIncludedIdx + 1] = includeResult[1] + excludeResult[1];
                }
            }
        }

        return count[0][0];
    }
}


//Optimal implementation 

class Solution {
    public int findNumberOfLIS(int[] arr) {
        /*
        * Space Optimization (2D → 1D):
        *
        * In the tabulation approach, dp[i][*] and count[i][*] depend only on the next row,
        * i.e., dp[i + 1][*] and count[i + 1][*].
        *
        * Since there is no dependency on earlier rows, we do not need the full 2D tables.
        *
        * Therefore:
        * - nextRowDP / nextRowCount represent dp[i + 1][*] and count[i + 1][*]
        * - currentRowDP / currentRowCount represent dp[i][*] and count[i][*]
        *
        * After computing the current row, we shift:
        * current → next (for the next iteration)
        *
        * This reduces space from O(n²) → O(n),
        */
        int[] currentRowDP = new int[arr.length + 1];
        int[] nextRowDP = new int[arr.length + 1];
        int[] currentRowCount = new int[arr.length + 1];
        int[] nextRowCount = new int[arr.length + 1];

        for (int lastIncludedIdx = -1; lastIncludedIdx < arr.length; lastIncludedIdx++) {
            nextRowDP[lastIncludedIdx + 1] = 0;
            nextRowCount[lastIncludedIdx + 1] = 1;
        }

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int[] includeResult = new int[2];

                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] < arr[i]) {
                    includeResult[0] = 1 + nextRowDP[i + 1];
                    includeResult[1] = nextRowCount[i + 1];
                }

                int[] excludeResult = new int[2];

                excludeResult[0] = nextRowDP[lastIncludedIdx + 1];
                excludeResult[1] = nextRowCount[lastIncludedIdx + 1];

                if (includeResult[0] > excludeResult[0]) {
                    currentRowDP[lastIncludedIdx + 1] = includeResult[0];
                    currentRowCount[lastIncludedIdx + 1] = includeResult[1];
                } else if (excludeResult[0] > includeResult[0]) {
                    currentRowDP[lastIncludedIdx + 1] = excludeResult[0];
                    currentRowCount[lastIncludedIdx + 1] = excludeResult[1];
                } else {
                    currentRowDP[lastIncludedIdx + 1] = includeResult[0];
                    currentRowCount[lastIncludedIdx + 1] = includeResult[1] + excludeResult[1];
                }
            }

            int[] temp = currentRowDP;
            currentRowDP = nextRowDP;
            nextRowDP = temp;

            temp = currentRowCount;
            currentRowCount = nextRowCount;
            nextRowCount = temp;
        }

        return nextRowCount[0];
    }
}


//Alternate DP approach

class Solution {
    public int findNumberOfLIS(int[] arr) {
        /*
         * dp[i] → Length of the Longest Increasing Subsequence (LIS)
         *         ending at index i
         *
         * count[i] → Number of LIS of length dp[i]
         *            that end at index i
         */
        int[] dp = new int[arr.length];
        int[] count = new int[arr.length];

        int maxLengthLIS = 0;

        for (int i = 0; i < arr.length; i++) {
            int bestPrevLengthLIS = 0; // best LIS length among all j < i
            int ways = 0; // number of ways to achieve that best length

            for (int j = 0; j < i; j++) {
                if (arr[j] < arr[i]) {
                    /*
                    * Case 1: Found a strictly better (longer) LIS ending at j
                    * → Update best length and reset count (ways)
                    */
                    if (dp[j] > bestPrevLengthLIS) {
                        bestPrevLengthLIS = dp[j];
                        ways = count[j];
                    } else if (dp[j] == bestPrevLengthLIS) {
                        /*
                        * Case 2: Found another LIS of same best length
                        * → Accumulate number of ways
                        */
                        ways += count[j];
                    }
                }
            }

            /*
             * Length of LIS ending at i:
             * Extend the best previous LIS by including arr[i]
             */
            dp[i] = bestPrevLengthLIS + 1;

            maxLengthLIS = Math.max(maxLengthLIS, dp[i]);

            /*
             * Count logic:
             *
             * - If no valid previous element exists (ways == 0),
             *   then the element itself forms an LIS of length 1 → count = 1
             *
             * - Otherwise, we inherit the number of ways from previous best LIS,
             *   since we are just appending arr[i] to those subsequences
             */
            count[i] = (ways == 0) ? 1 : ways;
        }

        /*
         * Final answer:
         * Sum counts of all indices where LIS length is maximum
         */
        int totalCount = 0;

        for (int i = 0; i < arr.length; i++) {
            if (dp[i] == maxLengthLIS) {
                totalCount += count[i];
            }
        }

        return totalCount;
    }
}
