//Naive implementation

class Solution {
    public int findLongestChain(int[][] pairs) {
        /*
        * dp[index][lastIncludedIndex + 1] represents:
        * "Maximum length of chain that can be formed starting from index 'index',
        * given the last included pair's index."
        *
        * Why (lastIncludedIndex + 1)?
        * - lastIncludedIndex can be -1 (no pair chosen yet)
        * - Array indices cannot be negative
        * - So we shift it by +1:
        *     -1 → 0, 0 → 1, 1 → 2, ...
        */
        int[][] dp = new int[pairs.length + 1][pairs.length + 1];

        Arrays.sort(pairs, (pair1, pair2) -> {
            return Integer.compare(pair1[1], pair2[1]);
        });

        for (int lastIncludedIndex = -1; lastIncludedIndex < pairs.length; lastIncludedIndex++) {
            dp[pairs.length][lastIncludedIndex + 1] = 0;
        }

        for (int i = pairs.length - 1; i >= 0; i--) {
            for (int lastIncludedIndex = pairs.length - 1; lastIncludedIndex >= -1; lastIncludedIndex--) {
                int include = 0;

                if (lastIncludedIndex == -1 || pairs[lastIncludedIndex][1] < pairs[i][0]) {
                    include = 1 + dp[i + 1][i + 1];
                }

                int exclude = dp[i + 1][lastIncludedIndex + 1];

                dp[i][lastIncludedIndex + 1] = Math.max(include, exclude);
            }
        }

        return dp[0][0];
    }
}


