/*
 * Why do we sort pairs by their end value?
 *
 * Sorting by end ensures that we always consider the pair that finishes earliest first.
 * This is important because choosing a pair with a smaller end leaves more room
 * for subsequent pairs to be included in the chain.
 *
 * If we pick a pair that ends later, it may block multiple valid pairs that could
 * have formed a longer chain.
 *
 * By processing pairs in increasing order of their end values, we make a greedy choice:
 * at each step, select the next pair that starts after the last selected pair ends.
 *
 * This guarantees that we maximize the number of pairs in the chain.
 */

//Bruteforce approach

class Solution {
    public int findLongestChain(int[][] pairs) {
        // Sort pairs by the end value (second element) of each pair in ascending order.
        Arrays.sort(pairs, (pair1, pair2) -> {
            return Integer.compare(pair1[1], pair2[1]);
        });

        return findLongestChain(pairs, 0, -1);
    }

    private int findLongestChain(int[][] pairs, int index, int lastIncludedIndex) {
        // Base case: if we've reached the end of the pairs array, return 0 (no more pairs can be added)
        if (index == pairs.length) {
            return 0;
        }

        int include = 0;
        /*
         * Option 1: Try to include the current pair in the chain if it can follow the
         * last included pair, or it is the first pair in the chain (there's no previous pair included),
         * because each pair can start its own chain.
         */
        if (lastIncludedIndex == -1 || pairs[lastIncludedIndex][1] < pairs[index][0]) {
            include = 1 + findLongestChain(pairs, index + 1, index);
        }

        // Option 2: Exclude the current pair and move to the next pair, keeping lastIncludedIndex the same.
        int exclude = findLongestChain(pairs, index + 1, lastIncludedIndex);

        // Return the maximum of including or excluding the current pair to get the longest chain.
        return Math.max(include, exclude);
    }
}



//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[index][lastIncludedIndex + 1] stores the maximum length of chain
    * that can be formed starting from the current index,
    * given the last included pair's index.
    *
    * Why (lastIncludedIndex + 1)?
    * - lastIncludedIndex can be -1 (no pair chosen yet)
    * - Array indices cannot be negative
    * - So we shift it by +1 to map:
    *     -1 → 0
    *      0 → 1
    *      1 → 2
    *      ...
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum chain length for this state
    *
    * State definition:
    * - index → current index in the pairs array
    * - lastIncludedIndex → index of the last pair included in the chain
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int findLongestChain(int[][] pairs) {
        dp = new Integer[pairs.length][pairs.length];

        Arrays.sort(pairs, (pair1, pair2) -> {
            return Integer.compare(pair1[1], pair2[1]);
        });

        return findLongestChain(pairs, 0, -1);
    }

    private int findLongestChain(int[][] pairs, int index, int lastIncludedIndex) {
        if (index == pairs.length) {
            return 0;
        }

        if (dp[index][lastIncludedIndex + 1] != null) {
            return dp[index][lastIncludedIndex + 1];
        }

        int include = 0;

        if (lastIncludedIndex == -1 || pairs[lastIncludedIndex][1] < pairs[index][0]) {
            include = 1 + findLongestChain(pairs, index + 1, index);
        }

        int exclude = findLongestChain(pairs, index + 1, lastIncludedIndex);

        return dp[index][lastIncludedIndex + 1] = Math.max(include, exclude);
    }
}


