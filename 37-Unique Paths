//Naive implementation

class Solution {
    public int uniquePaths(int m, int n) {
        /*
        * dp[row][col] represents the number of unique paths to reach
        * the destination (bottom-right cell) starting from cell (row, col).
        */
        int[][] dp = new int[m + 1][n + 1];

        for (int col = 0; col < n; col++) {
            dp[m][col] = 0;
        }

        for (int row = 0; row < m; row++) {
            dp[row][n] = 0;
        }

        for (int row = m - 1; row >= 0; row--) {
            for (int col = n - 1; col >= 0; col--) {
                if (row == m - 1 && col == n - 1) {
                    dp[row][col] = 1;
                } else {
                    dp[row][col] = dp[row][col + 1] + dp[row + 1][col];
                }
            }
        }

        return dp[0][0];
    }
}


//Better implementation

class Solution {
    public int uniquePaths(int m, int n) {
        // dp[row][col] represents the total number of unique paths from cell (row, col) to the bottom-right corner of the grid (m-1, n-1).
        int[][] dp = new int[m][n];

        /*
         * If you are in the last row of the grid, you can only move right to reach the bottom-right corner.
         * So, there is only one unique path to reach the destination from any cell in the last row.
         */
        for (int j = 0; j <= n - 1; j++) {
            dp[m - 1][j] = 1;
        }

        /*
        * If you are in the last column of the grid, you can only move downward to reach the bottom-right corner.
        * So, there is only one unique path to reach the destination from any cell in the last column.
        */
        for (int i = 0; i <= m - 1; i++) {
            dp[i][n - 1] = 1;
        }

        for (int row = m - 2; row >= 0; row--) {
            for (int col = n - 2; col >= 0; col--) {
                dp[row][col] = dp[row][col + 1] + dp[row + 1][col];
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int uniquePaths(int m, int n) {
        /*
        * Space Optimization (from 2D → 1D):
        *
        * - In tabulation, dp[row][col] depends only on:
        *     → dp[row][col + 1]   (right cell in same row)
        *     → dp[row + 1][col]   (same column in next row)
        *
        * - Since each state depends only on the current row and the next row,
        *   we can replace the 2D dp array with two 1D arrays:
        *
        *     → currentRow[col] → represents dp[row][col]
        *     → nextRow[col]    → represents dp[row + 1][col]
        */
        int[] nextRow = new int[n];
        int[] currentRow = new int[n];

        for (int j = 0; j <= n - 1; j++) {
            nextRow[j] = 1;
        }

        for (int row = m - 2; row >= 0; row--) {
            currentRow[n - 1] = 1;
            for (int col = n - 2; col >= 0; col--) {
                currentRow[col] = currentRow[col + 1] + nextRow[col];
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}

