//Bruteforce Approach

class Solution {
    public int uniquePaths(int m, int n) {
        return uniquePaths(0, 0, m, n);
    }

    private int uniquePaths(int row, int col, int m, int n) {
        // Base case: If we reach the destination, there is exactly one valid path i.e staying there.
        if (row == m - 1 && col == n - 1) {
            return 1;
        }

        // Out of bounds → invalid path
        if (row == m || col == n) {
            return 0;
        }

        /*
        * Recursive Case:
        *
        * From any cell (row, col), we have two possible moves:
        *   → move right  → (row, col + 1)
        *   → move down   → (row + 1, col)
        *
        * - If we move right, we need to count how many ways exist
        *   to reach the destination from (row, col + 1).
        *
        * - If we move down, we need to count how many ways exist
        *   to reach the destination from (row + 1, col).
        *
        * - Each recursive call gives the number of valid paths from that position
        *   to the destination.
        *
        * - Since these paths are independent (a path either goes right first OR down first),
        *   we add both results to get the total number of paths from the current cell:
        *
        *     totalPaths = pathsMovingRight + pathsMovingDown
        *
        * - This way, we explore and count all possible paths that eventually
        *   lead to the bottom-right corner.
        */
        int pathsMovingRight = uniquePaths(row, col + 1, m, n);
        int pathsMovingDown = uniquePaths(row + 1, col, m, n);

        return pathsMovingRight + pathsMovingDown;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[row][col] stores the number of unique paths to reach the destination
    * starting from the current cell (row, col).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → number of paths from (row, col) to destination
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int uniquePaths(int m, int n) {
        dp = new Integer[m][n];
        return uniquePaths(0, 0, m, n);
    }

    private int uniquePaths(int row, int col, int m, int n) {
        if (row == m - 1 && col == n - 1) {
            return 1;
        }

        if (row == m || col == n) {
            return 0;
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int pathsMovingRight = uniquePaths(row, col + 1, m, n);
        int pathsMovingDown = uniquePaths(row + 1, col, m, n);

        return dp[row][col] = pathsMovingRight + pathsMovingDown;
    }
}


