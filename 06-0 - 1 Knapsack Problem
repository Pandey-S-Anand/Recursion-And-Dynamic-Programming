//Bruteforce Approach

/**
 * Why Greedy does NOT work for 0/1 Knapsack:
 *
 * In the 0/1 Knapsack problem, each item can either be:
 * - fully taken, or
 * - completely excluded
 *
 * Unlike Fractional Knapsack, we cannot take a fraction of an item.
 *
 * ------------------------------------------------------------
 *
 * Greedy strategies typically try to make a locally optimal choice, such as:
 * - Picking the item with maximum value
 * - Picking the item with minimum weight
 * - Picking the item with highest value/weight ratio
 *
 * However, these local decisions do NOT guarantee a globally optimal solution.
 *
 * ------------------------------------------------------------
 *
 * Counter Example:
 *
 * Capacity W = 50
 *
 * Item    Weight   Value   Value/Weight
 * ------------------------------------
 * A       10       60      6
 * B       20       100     5
 * C       30       120     4
 *
 * Greedy (based on value/weight ratio):
 * - Pick A (best ratio = 6) ? weight = 10, value = 60
 * - Pick B ? weight = 30, value = 160
 * - Cannot pick C (would exceed capacity)
 *
 * Total value = 160
 *
 * ------------------------------------------------------------
 *
 * Optimal Solution:
 * - Pick B and C ? total weight = 20 + 30 = 50
 * - Total value = 100 + 120 = 220 (better than 160)
 *
 *
 * Why Greedy Fails:
 *
 * Greedy makes locally optimal choices (e.g., highest value/weight),
 * but 0/1 Knapsack requires selecting the best combination of items.
 *
 * Since items cannot be split, choosing one item may prevent selecting
 * a better combination later. Hence, local decisions do not guarantee
 * a globally optimal solution.
 *
 * ------------------------------------------------------------
 * Conclusion:
 *
 * The problem lacks the greedy-choice property.
 * Therefore, we must explore both choices (take / not take),
 * which leads to a Dynamic Programming solution.
 */

public class Solution {
    static int knapsack(int[] weight, int[] value, int n, int maxCapacity) {
        return knapsack(weight, value, 0, n, maxCapacity);
    }

    private static int knapsack(int[] weight, int[] value, int index, int n, int capacity) {
        /*
         * Base Case 1: If the remaining capacity is 0, we cannot add any more items, so the maximum value obtainable is 0.
         * Base Case 2: If we have considered all items, there are no more items left to add, resulting in a value of 0.
         */
        if (capacity == 0 || index == n) {
            return 0;
        }

        int take = 0;
        // Check if we can include the current item (only if its weight is less than or equal to the remaining capacity)
        if (capacity >= weight[index]) {
            // If we can include the current item, add its value
            take = value[index] + knapsack(weight, value, index + 1, n, capacity - weight[index]);
        }

        // Exclude the current item
        int notTake = knapsack(weight, value, index + 1, n, capacity);

        // Return the maximum of including or excluding the current item
        return Math.max(take, notTake);
    }
}


//Better Approach

public class Solution {
    /*
    * Memoization:
    * dp[index][capacity] stores the maximum value that can be obtained
    * using items from index ? n-1 with remaining capacity = capacity.
    *
    * Meaning of values:
    * - null  ? this state has NOT been computed yet
    * - value ? maximum achievable value for this state
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private static Integer[][] dp;

    static int knapsack(int[] weight, int[] value, int n, int maxCapacity) {
        dp = new Integer[n][maxCapacity + 1];
        return knapsack(weight, value, 0, n, maxCapacity);
    }

    private static int knapsack(int[] weight, int[] value, int index, int n, int capacity) {
        if (capacity == 0 || index == n) {
            return 0;
        }

        if (dp[index][capacity] != null) {
            return dp[index][capacity];
        }

        int take = 0;

        if (capacity >= weight[index]) {
            take = value[index] + knapsack(weight, value, index + 1, n, capacity - weight[index]);
        }

        int notTake = knapsack(weight, value, index + 1, n, capacity);

        return dp[index][capacity] = Math.max(take, notTake);
    }
}


