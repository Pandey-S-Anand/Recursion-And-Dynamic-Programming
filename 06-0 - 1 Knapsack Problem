public class Solution {
    static int knapsack(int[] weight, int[] value, int n, int maxCapacity) {
        /*
        * dp[i][capacity] represents:
        * "Maximum value that can be obtained using items from index i to n-1
        * with remaining capacity = capacity."
        */
        int[][] dp = new int[n + 1][maxCapacity + 1];

        dp[n][0] = 0;

        for (int capacity = 1; capacity <= maxCapacity; capacity++) {
            dp[n][capacity] = 0;
        }

        for (int i = 0; i < n; i++) {
            dp[i][0] = 0;
        }

        for (int i = n - 1; i >= 0; i--) {
            for (int capacity = 1; capacity <= maxCapacity; capacity++) {
                int take = 0;

                if (capacity >= weight[i]) {
                    take = value[i] + dp[i + 1][capacity - weight[i]];
                }

                int notTake = dp[i + 1][capacity];

                dp[i][capacity] = Math.max(take, notTake);
            }
        }

        return dp[0][maxCapacity];
    }
}


