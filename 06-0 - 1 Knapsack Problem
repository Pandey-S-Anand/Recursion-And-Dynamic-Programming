//Optimal implementation

public class Solution {
    static int knapsack(int[] weight, int[] value, int n, int maxCapacity) {
        // Since dp[i][*] depends on dp[i+1][*], we use two arrays (currentRow and nextRow) to represent current and next states
        int[] currentRow = new int[maxCapacity + 1];
        int[] nextRow = new int[maxCapacity + 1];

        for (int i = n - 1; i >= 0; i--) {
            for (int capacity = 1; capacity <= maxCapacity; capacity++) {
                int take = 0;

                if (capacity >= weight[i]) {
                    take = value[i] + nextRow[capacity - weight[i]];
                }

                int notTake = nextRow[capacity];

                currentRow[capacity] = Math.max(take, notTake);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[maxCapacity];
    }
}
