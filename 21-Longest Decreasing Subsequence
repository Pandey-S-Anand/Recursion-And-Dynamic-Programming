//Bruteforce approach

public class Solution {
    public static int LDS(int[] arr) {
        return findLDSLength(arr, 0, -1);
    }

    private static int findLDSLength(int[] arr, int index, int lastIncludedIdx) {
        if (index == arr.length) {
            return 0;
        }

        // Option 1: Include the current element in the subsequence (if it creates an decreasing order)
        int included = Integer.MIN_VALUE;
        /*
         * Check if the current element is either the first element of the subsequence
         * (lastIncludedIdx == -1) or less than the last included element in the current subsequence.
         * 
         * lastIncludedIdx = -1 is used as a base case to indicate no prior element in the subsequence, 
         * allowing any element to start a new subsequence.
         * 
         * lastIncludedIdx can only take values from -1 up to one less than the current index
         */
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[index]) {
            included = 1 + findLDSLength(arr, index + 1, index);
        }

        // Option 2: Exclude the current element and move to the next index
        int excluded = findLDSLength(arr, index + 1, lastIncludedIdx);

        // Return the maximum length of LDS obtained by either including or excluding the current element
        return Math.max(included, excluded);
    }
}


//Good Approach

public class Solution {
    /*
    * Memoization:
    * dp[index][lastIncludedIdx + 1] stores the maximum length of LDS
    * that can be formed starting from the given index,
    * given the last included element's index.
    *
    * Why (lastIncludedIdx + 1)?
    * - lastIncludedIdx can be -1 (no element chosen yet)
    * - Array indices cannot be negative
    * - So we shift it by +1 to map:
    *      -1 ? 0
    *       0 ? 1
    *       1 ? 2
    *       ...
    *
    * Meaning of values:
    * - null  ? this state has NOT been computed yet
    * - value ? maximum LDS length for this state
    *
    * State definition:
    * - index ? current index in the array
    * - lastIncludedIdx ? index of the last element included in the subsequence
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private static Integer[][] dp;

    public static int LDS(int[] arr) {
        dp = new Integer[arr.length + 1][arr.length];
        return findLDSLength(arr, 0, -1);
    }

    private static int findLDSLength(int[] arr, int index, int lastIncludedIdx) {
        if (index == arr.length) {
            return 0;
        }

        if (dp[index][lastIncludedIdx + 1] != null) {
            return dp[index][lastIncludedIdx + 1];
        }

        int included = Integer.MIN_VALUE;

        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[index]) {
            included = 1 + findLDSLength(arr, index + 1, index);
        }

        int excluded = findLDSLength(arr, index + 1, lastIncludedIdx);

        return dp[index][lastIncludedIdx + 1] = Math.max(included, excluded);
    }
}


