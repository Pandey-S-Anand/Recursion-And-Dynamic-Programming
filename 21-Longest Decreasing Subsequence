//Naive implementation

public class Solution {
    public static int LDS(int[] arr) {
        /*
        * dp[index][lastIncludedIdx + 1] represents:
        * "Maximum length of LDS that can be formed starting from index 'index',
        * given the last included element's index."
        */
        int[][] dp = new int[arr.length + 1][arr.length + 1];

        for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
            dp[arr.length][lastIncludedIdx + 1] = 0;
        }

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int included = Integer.MIN_VALUE;
                /*
                * In tabulation, we store lastIncludedIdx as (lastIncludedIdx + 1)
                * to handle the case when lastIncludedIdx = -1.
                *
                * Since array indices cannot be negative, this shift maps:
                *   -1 ? 0, 0 ? 1, 1 ? 2, ...
                *
                * Hence, whenever accessing dp, we use (lastIncludedIdx + 1).
                */
                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[i]) {
                    included = 1 + dp[i + 1][i + 1];
                }

                int excluded = dp[i + 1][lastIncludedIdx + 1];

                dp[i][lastIncludedIdx + 1] = Math.max(included, excluded);
            }
        }

        return dp[0][0];
    }
}


//Better implementation

public class Solution {
    public static int LDS(int[] arr) {
        int[][] dp = new int[arr.length + 1][arr.length + 1];

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int included = Integer.MIN_VALUE;

                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[i]) {
                    included = 1 + dp[i + 1][i + 1];
                }

                int excluded = dp[i + 1][lastIncludedIdx + 1];

                dp[i][lastIncludedIdx + 1] = Math.max(included, excluded);
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

public class Solution {
    public static int LDS(int[] arr) {
        // Since dp[index][*] depends only on dp[index + 1][*], we use two 1D arrays (currentRow and nextRow) instead of a full 2D dp table
        int[] currentRow = new int[arr.length + 1];
        int[] nextRow = new int[arr.length + 1];

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int included = Integer.MIN_VALUE;

                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[i]) {
                    included = 1 + nextRow[i + 1];
                }

                int excluded = nextRow[lastIncludedIdx + 1];

                currentRow[lastIncludedIdx + 1] = Math.max(included, excluded);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}


//Aliter DP approach

public class Solution {
    public static int LDS(int[] arr) {
        // dp[i] = max length LDS ending at index i
        int[] dp = new int[arr.length];
        int maxLengthLIS = 0;

        for (int i = 0; i < arr.length; i++) {
            int prevBestLIS = 0;
            for (int j = 0; j < i; j++) {
                if (arr[i] < arr[j]) {
                    prevBestLIS = Math.max(prevBestLIS, dp[j]);
                }
            }
            dp[i] = prevBestLIS + 1;
            maxLengthLIS = Math.max(maxLengthLIS, dp[i]);
        }

        return maxLengthLIS;
    }
}


//Optimal approach

/*
 *   arr = [13, 10, 11, 7, 8, 6, 5, 9, 2]
 *
 *   Step-by-step tail evolution:
 *     1) [13]
 *     2) [13, 10]
 *     3) [13, 11] // replace 10 with 11
 *     4) [13, 11, 7] 
 *     5) [13, 11, 8]  // replace 7 with 8
 *     6) [13, 11, 8, 6] 
 *     7) [13, 11, 8, 6, 5] 
 *     8) [13, 11, 9, 6, 5]  //replace 8 with 9
 *     9) [13, 11, 9, 6, 5, 2] 
 *
 *   Final tail = [13, 11, 9, 6, 5, 2], length = 6
 *
 *   But [13, 11, 9, 6, 5, 2] is NOT a valid subsequence of `arr`, because
 *   9 (index 7) comes after 6 (index 5) in the original array.
 *
 * Reason for substitution:
 *   We always replace with a greater value (when possible) even though
 *   the current length of `tail` stays the same, because:
 *     1: A greater tail value opens up more room for future numbers
 *        to extend the subsequence.
 *     2: The greater the value at position i, the higher the chance
 *        that a later array element < tail[i], letting us grow length.
 *
 *
 * Mini example: arr = [1, 10, 8]
 *
 *   1) Process 1  => tail = [1]
 *
 *   2) Process 10 => replace 1 with 10 => tail = [10] (length still 1)
 *
 *   3) Process 8  => append 8 => tail = [10, 8] (length increases to 2)
 *
 *   Here, substituting 1 with 10 didnot change the length,
 *   but enabled appending 8 later to form a longer strictly decreasing subsequence.
 */
public class Solution {
    public static int LDS(int[] arr) {
        int[] tail = new int[arr.length];
        int length = 0;

        for (int num : arr) {
            int index = findFirstLessOrEqual(tail, length, num);

            if (index == length) {
                length++;
            }

            tail[index] = num;
        }

        return length;
    }

    //Find the index of greatest element that is smaller than or equal to the target
    private static int findFirstLessOrEqual(int[] arr, int n, int target) {
        int low = 0, high = n - 1, upperBound = n;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            if (arr[mid] <= target) {
                upperBound = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }

        return upperBound;
    }
}
