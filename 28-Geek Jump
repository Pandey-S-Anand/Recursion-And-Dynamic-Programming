//Bruteforce Approach

class Solution {
    int minCost(int[] height) {
        // Compute the minimum energy required to reach the last stair (index n-1) starting from the first stair (index 0).
        return minCost(0, height);
    }

    private int minCost(int currentStair, int[] height) {
        // Base case : If we have reached the destination stair, no energy is required further.
        if (currentStair == height.length - 1) {
            return 0;
        }

        /*
         * Recursive Case:
         *
         * From currentStair, we have two choices:
         *
         * 1. Jump 1 step → move to (currentStair + 1)
         *    - Cost of this jump:
         *        |height[currentStair + 1] - height[currentStair]|
         *    - Plus the cost to reach the end from (currentStair + 1)
         *
         * 2. Jump 2 steps → move to (currentStair + 2)
         *    - Cost of this jump:
         *        |height[currentStair + 2] - height[currentStair]|
         *    - Plus the cost to reach the end from (currentStair + 2)
         *
         * We take the minimum of both choices since we want minimum energy.
         *
         * If the jump exceeds the last stair index (n - 1), this jump is invalid and should be ignored.
         */
        int costFromNextStair = Integer.MAX_VALUE;

        if (currentStair + 1 <= height.length - 1) {
            costFromNextStair = Math.abs(height[currentStair + 1] - height[currentStair]) + minCost(currentStair + 1, height);
        }

        int costFromNextNextStair = Integer.MAX_VALUE;

        if (currentStair + 2 <= height.length - 1) {
            costFromNextNextStair = Math.abs(height[currentStair + 2] - height[currentStair]) + minCost(currentStair + 2, height);
        }

        // Return the minimum energy required between the 1-step jump and the 2-step jump.
        return Math.min(costFromNextStair, costFromNextNextStair);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[currentStair] stores the minimum energy required to reach
    * the last stair from the given currentStair.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum cost to reach the last stair from currentStair
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute it and store it in dp[currentStair]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    int minCost(int[] height) {
        dp = new Integer[height.length];

        return minCost(0, height);
    }

    private int minCost(int currentStair, int[] height) {
        if (currentStair == height.length - 1) {
            return 0;
        }

        if (dp[currentStair] != null) {
            return dp[currentStair];
        }

        int costFromNextStair = Integer.MAX_VALUE;

        if (currentStair + 1 <= height.length - 1) {
            costFromNextStair = Math.abs(height[currentStair + 1] - height[currentStair]) + minCost(currentStair + 1, height);
        }

        int costFromNextNextStair = Integer.MAX_VALUE;

        if (currentStair + 2 <= height.length - 1) {
            costFromNextNextStair = Math.abs(height[currentStair + 2] - height[currentStair]) + minCost(currentStair + 2, height);
        }

        return dp[currentStair] = Math.min(costFromNextStair, costFromNextNextStair);
    }
}


//Optimal Approach

class Solution {
    int minCost(int[] height) {
        // dp[i] represents the minimum energy consumed to reach last stair (height.length - 1) from i th stair
        int[] dp = new int[height.length];

        // Base case: No energy required to stay at the last stair.
        dp[height.length - 1] = 0;

        for (int stair = height.length - 2; stair >= 0; stair--) {
            int costFromNextStair = Integer.MAX_VALUE;

            if (stair + 1 <= height.length - 1) {
                costFromNextStair = Math.abs(height[stair + 1] - height[stair]) + dp[stair + 1];
            }

            int costFromNextNextStair = Integer.MAX_VALUE;

            if (stair + 2 <= height.length - 1) {
                costFromNextNextStair = Math.abs(height[stair + 2] - height[stair]) + dp[stair + 2];
            }

            dp[stair] = Math.min(costFromNextStair, costFromNextNextStair);
        }

        return dp[0];
    }
}
