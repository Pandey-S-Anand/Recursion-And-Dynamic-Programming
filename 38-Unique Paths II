//Bruteforce Approach

class Solution {
    public int uniquePathsWithObstacles(int[][] obstacle) {
        int rows = obstacle.length;
        int cols = obstacle[0].length;

        /*
        * If the starting point (top-left corner) or the destination (bottom-rightcorner)
        * itself is an obstacle, return 0 as no paths are possible to reach the bottom-right corner (i.e., grid[m - 1][n - 1]).
        */
        if (obstacle[0][0] == 1 || obstacle[rows - 1][cols - 1] == 1) {
            return 0;
        }

        return uniquePathsWithObstacles(obstacle, 0, 0, rows, cols);
    }

    private int uniquePathsWithObstacles(int[][] obstacle, int row, int col, int m, int n) {
        // Base case: If we reach the destination, there is exactly one valid path i.e staying there.
        if (row == m - 1 && col == n - 1) {
            return 1;
        }

        int pathsMovingRight = 0;

        // Check if moving right is within bounds and the cell is not an obstacle.
        if (col < n - 1 && obstacle[row][col + 1] == 0) {
            pathsMovingRight = uniquePathsWithObstacles(obstacle, row, col + 1, m, n);
        }

        int pathsMovingDown = 0;

        // Check if moving down is within bounds and the cell is not an obstacle.
        if (row < m - 1 && obstacle[row + 1][col] == 0) {
            pathsMovingDown = uniquePathsWithObstacles(obstacle, row + 1, col, m, n);
        }

        return pathsMovingRight + pathsMovingDown;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[row][col] stores the number of unique paths to reach the destination
    * starting from cell (row, col), considering obstacles.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → number of valid paths from (row, col) to destination
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int uniquePathsWithObstacles(int[][] obstacle) {
        int rows = obstacle.length;
        int cols = obstacle[0].length;

        if (obstacle[0][0] == 1 || obstacle[rows - 1][cols - 1] == 1) {
            return 0;
        }

        dp = new Integer[rows][cols];

        return uniquePathsWithObstacles(obstacle, 0, 0, rows, cols);
    }

    private int uniquePathsWithObstacles(int[][] obstacle, int row, int col, int m, int n) {
        if (row == m - 1 && col == n - 1) {
            return 1;
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int pathsMovingRight = 0;

        if (col < n - 1 && obstacle[row][col + 1] == 0) {
            pathsMovingRight = uniquePathsWithObstacles(obstacle, row, col + 1, m, n);
        }

        int pathsMovingDown = 0;

        if (row < m - 1 && obstacle[row + 1][col] == 0) {
            pathsMovingDown = uniquePathsWithObstacles(obstacle, row + 1, col, m, n);
        }

        return dp[row][col] = pathsMovingRight + pathsMovingDown;
    }
}


