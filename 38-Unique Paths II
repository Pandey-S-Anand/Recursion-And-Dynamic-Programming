//Naive implementation

class Solution {
    public int uniquePathsWithObstacles(int[][] obstacle) {
        int m = obstacle.length;
        int n = obstacle[0].length;

        if (obstacle[0][0] == 1 || obstacle[m - 1][n - 1] == 1) {
            return 0;
        }

        /*
        * dp[row][col] represents the number of unique paths to reach
        * the destination (bottom-right cell) starting from cell (row, col),
        * considering obstacles.
        *
        * - If a move leads to a blocked cell (obstacle == 1), that path is ignored.
        * - Only unblocked (obstacle == 0) right and down moves contribute to dp[row][col].
        */
        int[][] dp = new int[m][n];

        for (int row = m - 1; row >= 0; row--) {
            for (int col = n - 1; col >= 0; col--) {
                if (row == m - 1 && col == n - 1) {
                    dp[row][col] = 1;
                } else {
                    int pathsMovingRight = 0;

                    if (col < n - 1 && obstacle[row][col + 1] == 0) {
                        pathsMovingRight = dp[row][col + 1];
                    }

                    int pathsMovingDown = 0;

                    if (row < m - 1 && obstacle[row + 1][col] == 0) {
                        pathsMovingDown = dp[row + 1][col];
                    }

                    dp[row][col] = pathsMovingRight + pathsMovingDown;
                }
            }
        }

        return dp[0][0];
    }
}


//Better implementation

class Solution {
    public int uniquePathsWithObstacles(int[][] obstacle) {
        int m = obstacle.length;
        int n = obstacle[0].length;

        if (obstacle[0][0] == 1 || obstacle[m - 1][n - 1] == 1) {
            return 0;
        }

        /*
        * dp[row][col] represents the number of unique paths to reach
        * the destination (m-1, n-1) starting from cell (row, col),
        * while avoiding obstacles.
        */
        int[][] dp = new int[m][n];

        dp[m - 1][n - 1] = 1; // Base case: At the destination cell, there is exactly one way — staying there.

        for (int col = n - 2; col >= 0; col--) {
            /*
            * In the last row, we can only move right.
            * - If there are no obstacles, each cell would have exactly 1 path.
            * - With obstacles:
            *     → A cell has 1 path only if:
            *         (current cell is not blocked) AND
            *         (the cell to the right has a valid path)
            *     → Otherwise, it has 0 paths.
            */
            if (obstacle[m - 1][col] == 0 && dp[m - 1][col + 1] == 1) {
                dp[m - 1][col] = 1;
            } else {
                dp[m - 1][col] = 0;
            }
        }

        for (int row = m - 2; row >= 0; row--) {
            /*
            * In the last column, we can only move down.
            * - If there are no obstacles, each cell would have exactly 1 path.
            * - With obstacles:
            *     → A cell has 1 path only if:
            *         (current cell is not blocked) AND
            *         (the cell below has a valid path)
            *     → Otherwise, it has 0 paths.
            */
            if (obstacle[row][n - 1] == 0 && dp[row + 1][n - 1] == 1) {
                dp[row][n - 1] = 1;
            } else {
                dp[row][n - 1] = 0;
            }
        }

        for (int row = m - 2; row >= 0; row--) {
            for (int col = n - 2; col >= 0; col--) {
                int pathsMovingRight = 0;

                if (obstacle[row][col + 1] == 0) {
                    pathsMovingRight = dp[row][col + 1];
                }

                int pathsMovingDown = 0;

                if (obstacle[row + 1][col] == 0) {
                    pathsMovingDown = dp[row + 1][col];
                }

                dp[row][col] = pathsMovingRight + pathsMovingDown;
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int uniquePathsWithObstacles(int[][] obstacle) {
        int m = obstacle.length;
        int n = obstacle[0].length;

        if (obstacle[0][0] == 1 || obstacle[m - 1][n - 1] == 1) {
            return 0;
        }

        /*
        * Space Optimization (from 2D → 1D):
        *
        * - In the 2D DP approach, dp[row][col] depends only on:
        *     → dp[row][col + 1]  
        *     → dp[row + 1][col]
        *
        * - Since each state depends only on the current row and the next row,
        *   we do not need the entire 2D dp array.
        *
        * - Instead, we use two 1D arrays:
        *     → currentRow[col] → represents dp[row][col]
        *     → nextRow[col]    → represents dp[row + 1][col]
        *
        * - This allows us to compute the current row using:
        *     → currentRow[col + 1] (right)
        *     → nextRow[col]        (down)
        *
        * - After processing a row:
        *     → currentRow becomes nextRow for the next iteration
        */
        int[] currentRow = new int[n];
        int[] nextRow = new int[n];

        nextRow[n - 1] = 1;

        for (int col = n - 2; col >= 0; col--) {
            if (obstacle[m - 1][col] == 0 && nextRow[col + 1] == 1) {
                nextRow[col] = 1;
            } else {
                nextRow[col] = 0;
            }
        }

        for (int row = m - 2; row >= 0; row--) {
            if (obstacle[row][n - 1] == 0 && nextRow[n - 1] == 1) {
                currentRow[n - 1] = 1;
            } else {
                currentRow[n - 1] = 0;
            }

            for (int col = n - 2; col >= 0; col--) {
                int pathsMovingRight = 0;

                if (obstacle[row][col + 1] == 0) {
                    pathsMovingRight = currentRow[col + 1];
                }

                int pathsMovingDown = 0;

                if (obstacle[row + 1][col] == 0) {
                    pathsMovingDown = nextRow[col];
                }

                currentRow[col] = pathsMovingRight + pathsMovingDown;
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}
