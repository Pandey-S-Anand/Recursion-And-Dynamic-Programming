//Naive implementation

class Solution {
    public int minInsertions(int arr[], int n) {
        return n - findLNDSLength(arr);
    }

    private int findLNDSLength(int[] arr) {
        /*
        * dp[index][lastIncludedIdx + 1] represents:
        * "Maximum length of LNDS that can be formed starting from index 'index',
        * given the last included element's index."
        */
        int[][] dp = new int[arr.length + 1][arr.length + 1];

        for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
            dp[arr.length][lastIncludedIdx + 1] = 0;
        }

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int included = Integer.MIN_VALUE;
                /*
                * In tabulation, we store lastIncludedIdx as (lastIncludedIdx + 1)
                * to handle the case when lastIncludedIdx = -1.
                *
                * Since array indices cannot be negative, this shift maps:
                *   -1 → 0, 0 → 1, 1 → 2, ...
                *
                * Hence, whenever accessing dp, we use (lastIncludedIdx + 1).
                */
                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] <= arr[i]) {
                    included = 1 + dp[i + 1][i + 1];
                }

                int excluded = dp[i + 1][lastIncludedIdx + 1];

                dp[i][lastIncludedIdx + 1] = Math.max(included, excluded);
            }
        }

        return dp[0][0];
    }
}


