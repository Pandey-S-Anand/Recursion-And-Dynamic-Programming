//Optimal implementation

class Solution {
    public int minInsertions(int arr[], int n) {
        return n - findLNDSLength(arr);
    }

    private int findLNDSLength(int[] arr) {
        // Since dp[index][*] depends only on dp[index + 1][*], we use two 1D arrays (currentRow and nextRow) instead of a full 2D dp table
        int[] currentRow = new int[arr.length + 1];
        int[] nextRow = new int[arr.length + 1];

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int lastIncludedIdx = arr.length - 1; lastIncludedIdx >= -1; lastIncludedIdx--) {
                int included = Integer.MIN_VALUE;

                if (lastIncludedIdx == -1 || arr[lastIncludedIdx] <= arr[i]) {
                    included = 1 + nextRow[i + 1];
                }

                int excluded = nextRow[lastIncludedIdx + 1];

                currentRow[lastIncludedIdx + 1] = Math.max(included, excluded);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}


//Aliter DP approach

class Solution {
    /*
    Following is the approach to find the Longest Non Decreasing Subsequence (LNDS) in the array by calculating the LNDS ending at each index:
    
    Approach :
    
    Subsequence Ending at Each Index:
    Every non decreasing subsequence in the array must end at some index `i`. 
    So, we focus on calculating the length of the (LNDS) that ends at each index `i`.
    Once we know the LNDS length for each ending index, the longest LNDS in the array 
    will be the maximum length among these values.
    
    Finding Potential LNDS Candidates:
    For each element `arr[i]`, we look at all previous elements `arr[j]` (where `j < i`).
    If `arr[i]` is greater than equal to `arr[j]`, then `arr[i]` can extend the non decreasing subsequence that ends at `arr[j]` by 1.
    
    Updating the LNDS Length for Each `i`:
    - For each valid candidate `arr[j]`, we retrieve the LNDS ending at `j` (stored in `dp[j]`).
    - Among all such candidates, the longest subsequence ending at `j` provides the longest possible subsequence that `i` can extend.
    - Finally, we add 1 to this length to include the current element `arr[i]`, which gives us the LNDS length ending at `i`.
    
    Final Step:
    After calculating the LNDS ending at each index, the overall longest LNDS in the array is simply the maximum value in the `dp` array.
    */
    public int minInsertions(int arr[], int n) {
        return n - findLNDSLength(arr);
    }

    private int findLNDSLength(int[] arr) {
        // dp[i] = max length LNDS ending at index i
        int[] dp = new int[arr.length];
        int overallMaxLengthLNDS = 0;

        for (int i = 0; i < arr.length; i++) {
            int maxLNDSLengthEndingBeforeI = 0;
            for (int j = 0; j < i; j++) {
                if (arr[i] >= arr[j]) {
                    maxLNDSLengthEndingBeforeI = Math.max(maxLNDSLengthEndingBeforeI, dp[j]);
                }
            }
            dp[i] = maxLNDSLengthEndingBeforeI + 1;
            overallMaxLengthLNDS = Math.max(overallMaxLengthLNDS, dp[i]);
        }

        return overallMaxLengthLNDS;
    }
}


//Optimal Approach

class Solution {
    /*
    *   arr = [2, 5, 3, 7, 11, 8, 10, 13, 6]
    *
    *   Step-by-step tail evolution:
    *     1) [2]
    *     2) [2, 5]
    *     3) [2, 3]       // replace 5 with 3
    *     4) [2, 3, 7]
    *     5) [2, 3, 7, 11]
    *     6) [2, 3, 7, 8] // replace 11 with 8
    *     7) [2, 3, 7, 8, 10]
    *     8) [2, 3, 7, 8, 10, 13]
    *     9) [2, 3, 6, 8, 10, 13] // replace 7 with 6
    *
    *   Final tail = [2, 3, 6, 8, 10, 13], length = 6
    *
    *   But [2,3,6,8,10,13] is NOT a valid subsequence of `arr`, because
    *   6 (index 8) comes after 8 (index 5) in the original array.
    *
    * Reason for substitution:
    *   We always replace with a smaller value (when possible) even though
    *   the current length of `tail` stays the same, because:
    *     – A smaller tail value “opens up” more room for future numbers
    *       to extend the subsequence.
    *     – The smaller the value at position i, the higher the chance
    *       that a later array element > tail[i], letting us grow length.
    *
    * Mini‑example: arr = [10, 1, 3]
    *   1) Process 10 → tail = [10]
    *   2) Process 1  → replace 10 with 1 → tail = [1] (length still 1)
    *   3) Process 3  → append → tail = [1, 3] (length increases to 2)
    *
    *   Here, substituting 10→1 didn’t change the length, but enabled
    *   appending 3 later to form a longer non decreasing subsequence.
    */
    public int minInsertions(int arr[], int n) {
        return n - findLNDSLength(arr);
    }

    private int findLNDSLength(int[] arr) {
        int[] tail = new int[arr.length];
        int length = 0;

        for (int num : arr) {
            int index = findUpperBound(tail, length, num);

            if (index == length) {
                length++;
            }

            tail[index] = num;
        }

        return length;
    }

    //Find the smallest element that is greater than the target
    private int findUpperBound(int[] arr, int n, int target) {
        int low = 0, high = n - 1, lowerBound = n;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            if (arr[mid] > target) {
                lowerBound = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }

        return lowerBound;
    }
}
