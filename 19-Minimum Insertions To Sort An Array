/*
 * Problem Insight:
 *
 * We need to sort the array using minimum number of moves,
 * where each move consists of removing an element and inserting it at any position.
 *
 * To minimize the number of moves, we should keep as many elements as possible
 * in their correct relative order and move only the remaining ones.
 *
 * The Longest Increasing Subsequence (LIS) represents the maximum number of elements
 * already in sorted order (i.e., do not need to be moved).
 *
 * Important:
 * Since we are expected to form a sorted array (non-decreasing order),
 * adjacent elements can also be equal, i.e., arr[i] <= arr[i + 1].
 *
 * Therefore, instead of strictly increasing LIS, we must consider
 * the Longest Non-Decreasing Subsequence (LNDS),
 * allowing equal elements as well (arr[j] <= arr[i]).
 *
 * All elements not part of this subsequence must be repositioned.
 *
 * If:
 * N = total number of elements
 * L = length of LNDS
 *
 * Minimum number of steps required = N - L
 */

//Bruteforce Approach

class Solution {
    public int minInsertions(int arr[], int n) {
        return n - findLNDSLength(arr, 0, -1);
    }

    private int findLNDSLength(int[] arr, int index, int lastIncludedIdx) {
        if (index == arr.length) {
            return 0;
        }

        // Option 1: Include the current element in the subsequence (if it creates an increasing order)
        int include = 0;
        /*
         * Check if the current element is either the first element of the subsequence
         * (lastIncludedIdx == -1) or greater than or equal to the last included element in the current subsequence.
         * 
         * lastIncludedIdx = -1 is used as a base case to indicate no prior element in
         * the subsequence, allowing any element to start a new subsequence.
         */
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] <= arr[index]) {
            include = 1 + findLNDSLength(arr, index + 1, index);
        }

        // Option 2: Exclude the current element and move to the next index
        int exclude = findLNDSLength(arr, index + 1, lastIncludedIdx);

        // Return the maximum length of LIS obtained by either including or excluding the current element
        return Math.max(include, exclude);
    }
}


//Good Approach

class Solution {
    private Integer[][] dp;

    /*
    * Memoization:
    * dp[index][lastIncludedIdx + 1] stores the maximum length of LNDS
    * that can be formed starting from the given index,
    * given the last included element's index.
    *
    * Why (lastIncludedIdx + 1)?
    * - lastIncludedIdx can be -1 (no element chosen yet)
    * - Array indices cannot be negative
    * - So we shift it by +1 to map:
    *      -1 → 0
    *       0 → 1
    *       1 → 2
    *       ...
    *
    * Meaning of values:
    * - null  → this state has NOT been computed yet
    * - value → maximum LNDS length for this state
    *
    * State definition:
    * - index → current index in the array
    * - lastIncludedIdx → index of the last element included in the subsequence
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    public int minInsertions(int arr[], int n) {
        dp = new Integer[arr.length][arr.length + 1];
        return n - findLNDSLength(arr, 0, -1);
    }

    private int findLNDSLength(int[] arr, int index, int lastIncludedIdx) {
        if (index == arr.length) {
            return 0;
        }

        if (dp[index][lastIncludedIdx + 1] != null) {
            return dp[index][lastIncludedIdx + 1];
        }

        int included = Integer.MIN_VALUE;
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] <= arr[index]) {
            included = 1 + findLNDSLength(arr, index + 1, index);
        }

        int excluded = findLNDSLength(arr, index + 1, lastIncludedIdx);

        return dp[index][lastIncludedIdx + 1] = Math.max(included, excluded);
    }
}


