/*
 * Problem: Longest Bitonic Subsequence (LBS)
 *
 * A bitonic subsequence is one which:
 * - First strictly increases (LIS)
 * - Then strictly decreases (LDS)
 *
 * The peak element is common to both parts.
 *
 * ------------------------------------------------------------
 * Example:
 *
 * arr[] = [1, 11, 2, 10, 4, 5, 2, 1]
 *
 * Some longest bitonic subsequences:
 *
 * 1) [1, 2, 10, 4, 2, 1]
 *    Increasing part : [1, 2, 10]
 *    Decreasing part : [10, 4, 2, 1]
 *
 * 2) [1, 2, 10, 5, 2, 1]
 *    Increasing part : [1, 2, 10]
 *    Decreasing part : [10, 5, 2, 1]
 *
 * 3) [1, 11, 10, 4, 2, 1]
 *    Increasing part : [1, 11]
 *    Decreasing part : [11, 10, 4, 2, 1]
 *
 * 4) [1, 11, 10, 5, 2, 1]
 *    Increasing part : [1, 11]
 *    Decreasing part : [11, 10, 5, 2, 1]
 *
 * ------------------------------------------------------------
 * Key Concept:
 *
 * In a valid bitonic subsequence:
 * - The sequence strictly increases up to a peak element.
 * - After the peak, it strictly decreases.
 * - The peak is counted in both LIS and LDS.
 *
 * ------------------------------------------------------------
 * Approach:
 *
 * 1) Compute LIS[i]:
 *    - Length of the Longest Increasing Subsequence ending at index i
 *
 * 2) Compute LDS[i]:
 *    - Length of the Longest Decreasing Subsequence starting from index i
 *
 * 3) For each index i, treat it as the peak:
 *
 *       Bitonic Length = LIS[i] + LDS[i] - 1
 *
 *    (Subtract 1 to avoid counting the peak element twice)
 *
 * 4) The maximum value across all i gives the answer
 *
 * ------------------------------------------------------------
 * Insight:
 *
 * - Every index acts as a potential peak
 * - We combine "best increasing till i" and "best decreasing from i"
 * - This ensures continuity and valid bitonic structure
 */

//Bruteforce approach

class Solution {
    public static int longestBitonicSequence(int n, int[] arr) {
        if (n < 3) {
            return 0; // A valid bitonic sequence requires at least 3 elements.
        }

        int maxLengthBitonicSubsequence = 0;

        for (int i = 0; i < arr.length; i++) {
            /*
             * - By treating each index as the end of a subarray, the LIS at that index
             *   represents the longest increasing subsequence ending there.
             *
             * - Similarly, by treating each index as the start of a subarray, the LDS at
             *   that index represents the longest decreasing subsequence starting from there.
             */
            int lis = findLISEndingAt(arr, 0, i + 1, -1);
            int lds = findLDSStartingAt(arr, i, arr.length, -1);

            /*
             * In a subarray of size 3 or more:
             *
             * - A LIS value of 1 indicates that the considered subarray is strictly
             *   decreasing (e.g., {5, 3, 2}).
             *
             * - A LDS value of 1 indicates that the considered subarray is strictly
             *   increasing (e.g., {2, 3, 5}).
             *
             * For a valid bitonic subsequence, there must be both an increasing phase
             * and a decreasing phase.
             *
             * Therefore, if either LIS or LDS is 1, it means no valid transition exists,
             * making it an invalid bitonic subsequence.
             */
            if (lis == 1 || lds == 1) {
                continue;
            }

            maxLengthBitonicSubsequence = Math.max(maxLengthBitonicSubsequence, lis + lds - 1);
        }

        return maxLengthBitonicSubsequence;
    }

    private static int findLISEndingAt(int[] arr, int index, int n, int lastIncludedIdx) {
        if (index == n) {
            return 0;
        }

        // Option 1: Include the current element in the subsequence (if it creates an increasing order)
        int include = 0;

        /*
         * Check if the current element is either the first element of the subsequence
         * (lastIncludedIdx == -1) or greater than the last included element in the current subsequence.
         * 
         * lastIncludedIdx = -1 is used as a base case to indicate no prior element in the subsequence, 
         * allowing any element to start a new subsequence.
         * 
         * lastIncludedIdx can only take values from -1 up to one less than the current index
         */
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] < arr[index]) {
            include = 1 + findLISEndingAt(arr, index + 1, n, index);
        }

        // Option 2: Exclude the current element and move to the next index
        int exclude = findLISEndingAt(arr, index + 1, n, lastIncludedIdx);

        // Return the maximum length of LIS obtained by either including or excluding the current element
        return Math.max(include, exclude);
    }

    private static int findLDSStartingAt(int[] arr, int index, int n, int lastIncludedIdx) {
        if (index == n) {
            return 0;
        }

        // Option 1: Include the current element in the subsequence (if it creates an decreasing order)
        int include = 0;
        /*
         * Check if the current element is either the first element of the subsequence
         * (lastIncludedIdx == -1) or smaller than the last included element in the current subsequence.
         * 
         * lastIncludedIdx = -1 is used as a base case to indicate no prior element in the subsequence, 
         * allowing any element to start a new subsequence.
         * 
         * lastIncludedIdx can only take values from -1 up to one less than the current index
         */
        if (lastIncludedIdx == -1 || arr[lastIncludedIdx] > arr[index]) {
            include = 1 + findLDSStartingAt(arr, index + 1, n, index);
        }

        // Option 2: Exclude the current element and move to the next index
        int exclude = findLDSStartingAt(arr, index + 1, n, lastIncludedIdx);

        // Return the maximum length of LDS obtained by either including or excluding the current element
        return Math.max(include, exclude);
    }
}


//Optimal Approach

class Solution {
    public static int longestBitonicSequence(int n, int[] arr) {
        if (n < 3) {
            return 0;
        }

        int maxLengthBitonicSubsequence = 0;

        int lis[] = computeLISEndingAtEachIndex(arr);
        int lds[] = computeLDSStartingAtEachIndex(arr);

        for (int i = 0; i < arr.length; i++) {

            if (lis[i] == 1 || lds[i] == 1) {
                continue;
            }

            maxLengthBitonicSubsequence = Math.max(maxLengthBitonicSubsequence, lis[i] + lds[i] - 1);
        }

        return maxLengthBitonicSubsequence;
    }

    /*
    * Computes the length of the Longest Increasing Subsequence (LIS)
    * end at each index.
    *
    * Idea:
    * For every index i, we look at all elements to its left (j < i).
    * If arr[i] > arr[j], then we can extend the increasing subsequence
    * ending at j by including arr[i].
    *
    * So, for each i:
    *   dp[i] = 1 + max(dp[j]) for all j < i where arr[i] > arr[j]
    *
    * If no such j exists, dp[i] = 1 (the element itself).
    */
    private static int[] computeLISEndingAtEachIndex(int[] arr) {
        // dp[i] = max length LIS ending at index i
        int[] dp = new int[arr.length];

        for (int i = 0; i < arr.length; i++) {
            int prevBestLIS = 0;
            for (int j = 0; j < i; j++) {
                if (arr[j] < arr[i]) {
                    prevBestLIS = Math.max(prevBestLIS, dp[j]);
                }
            }
            dp[i] = prevBestLIS + 1;
        }

        return dp;
    }

    /*
    * Computes the length of the Longest Decreasing Subsequence (LDS)
    * starting at each index.
    *
    * Idea:
    * For every index i, we look at all elements to its right (j > i).
    * If arr[i] > arr[j], then we can extend the decreasing subsequence
    * starting at j by including arr[i].
    *
    * So, for each i:
    *   dp[i] = 1 + max(dp[j]) for all j > i where arr[i] > arr[j]
    *
    * If no such j exists, dp[i] = 1 (the element itself).
    */
    private static int[] computeLDSStartingAtEachIndex(int[] arr) {
        // dp[i] = max length LDS starting at index i
        int[] dp = new int[arr.length];

        for (int i = arr.length - 1; i >= 0; i--) {
            int maxLDSAhead = 0;
            for (int j = i + 1; j < arr.length; j++) {
                if (arr[i] > arr[j]) {
                    maxLDSAhead = Math.max(maxLDSAhead, dp[j]);
                }
            }
            dp[i] = maxLDSAhead + 1;
        }

        return dp;
    }
}
