/*
The triangle:

   2
  3 4
 6 5 7
4 1 8 3

is conceptually the same as:

2
3 4
6 5 7
4 1 8 3

*/

//Bruteforce Approach

class Solution {
    public int minimumTotal(List<List<Integer>> triangle) {
        // Start the recursive function from the top/peak of the triangle (row 0, column 0)
        return minimumTotal(triangle, 0, 0);
    }

    private int minimumTotal(List<List<Integer>> triangle, int row, int col) {
        /*
         * Base case:
         * If we reach the last row of the triangle, the minimum path sum
         * from this point is simply the value of the current cell.
         */
        if (row == triangle.size() - 1) {
            return triangle.get(row).get(col);
        }
        /*
         * Recursive case:
         * Calculate the minimum path sum for the two possible paths:
         * 1. Moving straight down to the next row at the same column (col).
         * 2. Moving diagonally down to the next row at the next column (col + 1).
         */
        int straightDown = minimumTotal(triangle, row + 1, col);
        int diagonalDown = minimumTotal(triangle, row + 1, col + 1);
        
        //Return the value of the current cell plus the minimum of the two possible paths.
        return triangle.get(row).get(col) + Math.min(straightDown, diagonalDown);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[row][col] stores the minimum path sum required to reach
    * the bottom of the triangle starting from position (row, col).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum cost from (row, col) to the bottom
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int minimumTotal(List<List<Integer>> triangle) {
        int totalRows = triangle.size();
        int lastRowSize = triangle.get(triangle.size() - 1).size();

        dp = new Integer[totalRows][lastRowSize];

        return minimumTotal(triangle, 0, 0);
    }

    private int minimumTotal(List<List<Integer>> triangle, int row, int col) {
        if (row == triangle.size() - 1) {
            return triangle.get(row).get(col);
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int straightDown = minimumTotal(triangle, row + 1, col);
        int diagonalDown = minimumTotal(triangle, row + 1, col + 1);

        return dp[row][col] = triangle.get(row).get(col) + Math.min(straightDown, diagonalDown);
    }
}


//Optimal Approach

//Naive implementation

class Solution {
    public int minimumTotal(List<List<Integer>> triangle) {
        int totalRows = triangle.size();
        int lastRowSize = triangle.get(triangle.size() - 1).size();

        /*
        * dp[row][col] represents the minimum path sum required to reach
        * the bottom of the triangle starting from position (row, col).
        */
        int[][] dp = new int[totalRows][lastRowSize];

        for (int col = 0; col <= totalRows - 1; col++) {
            dp[totalRows - 1][col] = triangle.get(totalRows - 1).get(col);
        }

        for (int row = totalRows - 2; row >= 0; row--) {
            for (int col = triangle.get(row).size() - 1; col >= 0; col--) {
                dp[row][col] = triangle.get(row).get(col) + Math.min(dp[row + 1][col], dp[row + 1][col + 1]);
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int minimumTotal(List<List<Integer>> triangle) {
        int totalRows = triangle.size();
        int lastRowSize = triangle.get(triangle.size() - 1).size();

        /*
        * Space Optimization (from 2D → 1D):
        *
        * - In the 2D DP approach, dp[row][col] depends only on:
        *     → dp[row + 1][col]       (straight down)
        *     → dp[row + 1][col + 1]   (diagonal down)
        *
        * - Since each state depends only on the next row,
        *   we do not need to store the entire 2D dp array.
        *
        * - Instead, we use two 1D arrays:
        *     → nextRow[col]    → represents dp[row + 1][col]
        *     → currentRow[col] → represents dp[row][col]
        *
        *     → currentRow becomes nextRow for the next iteration
        *
        * - This reduces space complexity from O(n²) → O(n)
        *   while preserving the same DP logic.
        */
        int[] nextRow = new int[lastRowSize];
        int[] currentRow = new int[lastRowSize];

        for (int col = 0; col <= totalRows - 1; col++) {
            nextRow[col] = triangle.get(totalRows - 1).get(col);
        }

        for (int row = totalRows - 2; row >= 0; row--) {
            for (int col = triangle.get(row).size() - 1; col >= 0; col--) {
                currentRow[col] = triangle.get(row).get(col) + Math.min(nextRow[col], nextRow[col + 1]);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}
