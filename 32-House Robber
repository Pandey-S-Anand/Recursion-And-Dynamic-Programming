//Bruteforce Approach

class Solution {
    public int rob(int[] arr) {
        return rob(arr, 0);
    }

    private int rob(int[] arr, int index) {
        // Base case: if the index is out of bounds, return 0 because there are no more houses to rob
        if (index >= arr.length) {
            return 0;
        }

        // Option 1: Rob the current house (arr[index]) and move to the next house that can be robbed, i.e., index + 2
        int rob = arr[index] + rob(arr, index + 2);
        // Option 2: Skip the current house and move to the next house, i.e., index + 1
        int notRob = rob(arr, index + 1);

        // Return the maximum of robbing the current house or skipping it
        return Math.max(rob, notRob);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[index] stores the maximum amount of money that can be robbed
    * starting from the current house (index).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum money that can be robbed starting from this index
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[index]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int rob(int[] arr) {
        dp = new Integer[arr.length];
        return rob(arr, 0);
    }

    private int rob(int[] arr, int index) {
        if (index >= arr.length) {
            return 0;
        }

        if (dp[index] != null) {
            return dp[index];
        }

        int rob = arr[index] + rob(arr, index + 2);
        int notRob = rob(arr, index + 1);

        return dp[index] = Math.max(rob, notRob);
    }
}


