//Naive Implementation

class Solution {
    public int rob(int[] arr) {
        //dp[i] stores the maximum money that can be robbed starting from index i.
        int[] dp = new int[arr.length + 2];

        // Base case: dp[arr.length] and dp[arr.length+1] represent positions beyond the last house,so no money can be robbed → both are initialized to 0.
        dp[arr.length] = dp[arr.length + 1] = 0;

        for (int i = arr.length - 1; i >= 0; i--) {
            int rob = arr[i] + dp[i + 2];
            int notRob = dp[i + 1];
            dp[i] = Math.max(rob, notRob);
        }

        return dp[0];
    }
}

//Optimal implementation

class Solution {
    public int rob(int[] arr) {
        /*
        * Space Optimization:
        *
        * - In the tabulation approach, dp[i] depends only on:
        *     → dp[i + 1] (next)
        *     → dp[i + 2] (nextNext)
        *
        * - Since we only need the next two states at any time,
        *   we can avoid maintaining the entire dp array.
        *
        * - Instead, we use two variables:
        *     → nextProfit     = dp[i + 1]
        *     → nextNextProfit = dp[i + 2]
        *
        * - After computing currentProfit (dp[i]):
        *     → shift the variables forward:
        *         nextNextProfit = nextProfit
        *         nextProfit = currentProfit
        */
        int nextProfit = 0, nextNextProfit = 0;

        for (int i = arr.length - 1; i >= 0; i--) {
            int rob = arr[i] + nextNextProfit;
            int notRob = nextProfit;
            int currentProfit = Math.max(rob, notRob);

            int temp = nextProfit;
            nextProfit = currentProfit;
            nextNextProfit = temp;
        }

        return nextProfit;
    }
}
