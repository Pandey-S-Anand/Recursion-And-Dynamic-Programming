//Bruteforce Approach

/*
 * stones = [0, 1, 3, 5, 6, 8, 12, 17]
 * The river is divided into continuous units from 0 to some maximum value
 * (e.g., 0 to 17 in the example).
 * Some of these units contain stones, and some contain water:
 * Units that contain stones are explicitly provided in the array stones.
 * i.e., stones[i] represents that a stone is present at unit stones[i].
 * Units not listed in the array contain water.
 * 
 * As per the problem statement, the frog starts at unit 0, and unit 0 contains a stone.
 * i.e., stones[0] = 0.
 * 
 * Since the stones array is sorted, the 0th unit will be present in stones array 
 * at the 0th index.
 */
class Solution {
    public boolean canCross(int[] stones) {
        /*
        * Since the frog can only make a 1-unit jump from unit 0,
        * the first jump must land at unit 1.
        * Therefore, unit 1 must contain a stone for the frog to proceed.
        * 
        * Since the stones array is sorted in ascending order,
        * unit 1 will be present in the stones array at the 1st index.
        */
        if (stones[1] != 1) {
            return false;
        }

        // Start from the second unit (index 1) with lastJump = 1.(i.e from unit 0 to unit 1)
        return canReachLastStone(stones, 1, 1);
    }

    private boolean canReachLastStone(int[] stones, int index, int lastJump) {
        /*
        * If you reach the last stone (stones[stones.length - 1]), return true.
        * The problem implicitly guarantees that the last stone is at the last unit of the river.
        * Since the stones array is sorted in ascending order, the last stone is always
        * at index stones.length - 1.
        */
        if (index == stones.length - 1) {
            return true;
        }

        // Try all possible jumps (lastJump-1, lastJump, lastJump+1) from the current unit.
        for (int nextJump = lastJump - 1; nextJump <= lastJump + 1; nextJump++) {
            if (nextJump == 0) {
                continue;
            }

            // Now check if the stone is present at next unit i.e stones[index] + nextJump
            int nextIndex = findNextStoneIndex(stones, index, nextJump);

            // If stone is present at 'next unit' then frog can jump there, recurse further.
            if (nextIndex != -1 && canReachLastStone(stones, nextIndex, nextJump)) {
                // If the frog successfully reaches the last stone from the next unit, return true
                return true;
            }
            // If there is no stone at the 'next unit' or the frog can not reach the last stone from the next unit, try the next possible jump
        }

        // If no valid jumps work, return false.
        return false;
    }

    private int findNextStoneIndex(int[] stones, int index, int jump) {
        int targetStone = stones[index] + jump;

        for (int i = index + 1; i < stones.length; i++) {
            if (stones[i] == targetStone) {
                return i; // return index of the next unit i.e stone exist at next unit
            }
        }

        return -1;// Return -1 if the stone doesn't exist at next unit.
    }
}


//Improved Approach

class Solution {
    /*
     * Optimization:
     * - Instead of linearly searching for the next stone (O(n) per lookup),
     *   we precompute a map: stone position → index.
     *
     * - This allows us to check whether the target stone exists and retrieve its index
     *   in O(1) time using the map.
     */
    private Map<Integer, Integer> stoneIndexMap;

    public boolean canCross(int[] stones) {
        if (stones[1] != 1) {
            return false;
        }

        stoneIndexMap = new HashMap<>();

        for (int i = 0; i < stones.length; i++) {
            stoneIndexMap.put(stones[i], i);
        }

        return canReachLastStone(stones, 1, 1);
    }

    private boolean canReachLastStone(int[] stones, int index, int lastJump) {
        if (index == stones.length - 1) {
            return true;
        }

        for (int nextJump = lastJump - 1; nextJump <= lastJump + 1; nextJump++) {
            if (nextJump == 0) {
                continue;
            }

            int nextIndex = stoneIndexMap.getOrDefault(stones[index] + nextJump, -1);

            if (nextIndex != -1 && canReachLastStone(stones, nextIndex, nextJump)) {
                return true;
            }
        }

        return false;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[index][lastJump] stores whether it is possible to reach the last stone
    * starting from the current state defined by (index, lastJump).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - 1    → it is possible to reach the last stone from this state (true)
    * - 0    → it is NOT possible to reach the last stone from this state (false)
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store the result in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private Map<Integer, Integer> stoneIndexMap;
    private Integer[][] dp;

    public boolean canCross(int[] stones) {
        if (stones[1] != 1) {
            return false;
        }

        stoneIndexMap = new HashMap<>();
        dp = new Integer[stones.length][stones.length];

        for (int i = 0; i < stones.length; i++) {
            stoneIndexMap.put(stones[i], i);
        }

        return canReachLastStone(stones, 1, 1);
    }

    private boolean canReachLastStone(int[] stones, int index, int lastJump) {
        if (index == stones.length - 1) {
            return true;
        }

        if (dp[index][lastJump] != null) {
            return dp[index][lastJump] == 1;
        }

        for (int nextJump = lastJump - 1; nextJump <= lastJump + 1; nextJump++) {
            if (nextJump == 0) {
                continue;
            }

            int nextIndex = stoneIndexMap.getOrDefault(stones[index] + nextJump, -1);

            if (nextIndex != -1 && canReachLastStone(stones, nextIndex, nextJump)) {
                dp[index][lastJump] = 1;
                return true;
            }
        }
        dp[index][lastJump] = 0;
        return false;
    }
}


//Optimal Approach

class Solution {
    private Integer[][] dp;

    public boolean canCross(int[] stones) {
        if (stones[1] != 1) {
            return false;
        }

        dp = new Integer[stones.length][stones.length];

        return canReachLastStone(stones, 1, 1);
    }

    private boolean canReachLastStone(int[] stones, int index, int lastJump) {
        if (index == stones.length - 1) {
            return true;
        }

        if (dp[index][lastJump] != null) {
            return dp[index][lastJump] == 1;
        }

        for (int nextJump = lastJump - 1; nextJump <= lastJump + 1; nextJump++) {
            if (nextJump == 0) {
                continue;
            }

            int nextIndex = findNextStoneIndex(stones, index, stones.length - 1, stones[index] + nextJump);

            if (nextIndex != -1 && canReachLastStone(stones, nextIndex, nextJump)) {
                dp[index][lastJump] = 1;
                return true;
            }
        }
        dp[index][lastJump] = 0;
        return false;
    }

    // Perform binary search to find if the stone is present at target unit since the stones array is sorted in ascending order
    private int findNextStoneIndex(int[] arr, int low, int high, int target) {
        while (low <= high) {
            int mid = (low + high) / 2;

            if (arr[mid] == target) {
                return mid;
            } else if (arr[mid] < target) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }

        return -1;
    }
}
