//Bruteforce Approach

class Solution {
    int maxLengthLis = 0;
    private ArrayList<Integer> longestIncreasingSubsequence;

    public ArrayList<Integer> longestIncreasingSubsequence(int n, int arr[]) {
        generateLIS(arr, 0, -1, n, new ArrayList<>());
        return longestIncreasingSubsequence;
    }

    private void generateLIS(int[] arr, int index, int lastIncludedIndex, int n, List<Integer> increasingSubsequence) {
        if (index == n) {
            if (increasingSubsequence.size() > maxLengthLis) {
                maxLengthLis = increasingSubsequence.size();
                longestIncreasingSubsequence = new ArrayList<>(increasingSubsequence);
            }
            return;
        }

        if (lastIncludedIndex == -1 || arr[lastIncludedIndex] < arr[index]) {
            increasingSubsequence.add(arr[index]);
            generateLIS(arr, index + 1, index, n, increasingSubsequence);
            increasingSubsequence.remove(increasingSubsequence.size() - 1); // Backtrack
        }

        generateLIS(arr, index + 1, lastIncludedIndex, n, increasingSubsequence);
    }
}


//Optimal Approach

class Solution {
    public ArrayList<Integer> getLIS(int arr[]) {
        int maxLengthLis = 0;
        int lisEndIndex = -1; // 'lisEndIndex' points to the last element of the LIS (i.e., where LIS ends)

        // dp[i] → Length of the longest increasing subsequence ending at index i
        int[] dp = new int[arr.length];
        /*
        prevIndex[i] → Stores the index of the previous element in the LIS 
        ending at index i (i.e., the element chosen just before arr[i] in that subsequence)  
        */
        int[] previousIndex = new int[arr.length];

        for (int i = 0; i < arr.length; i++) {
            int bestPrevLISLength = 0;
            int bestPrevLISIdx = -1;

            for (int j = 0; j < i; j++) {
                if (arr[j] < arr[i]) {
                    if (dp[j] > bestPrevLISLength) {
                        bestPrevLISLength = dp[j];
                        bestPrevLISIdx = j;
                    }
                }
            }

            previousIndex[i] = bestPrevLISIdx;

            dp[i] = bestPrevLISLength + 1;

            if (dp[i] > maxLengthLis) {
                maxLengthLis = dp[i];
                lisEndIndex = i;
            }
        }

        /*
        * We backtrack the LIS in reverse using the parent pointers:
        *
        * previousIndex[i] tells us:
        * "which element came just before arr[i] in the LIS"
        *
        * So we keep moving:
        * current index → its previous index → its previous → ...
        * until we reach -1 (start of subsequence)
        *
        */
        ArrayList<Integer> lis = new ArrayList<>();

        int idx = lisEndIndex;

        while (previousIndex[idx] != -1) {
            lis.add(arr[idx]);
            idx = previousIndex[idx];
        }

        /*
        * At this point, 'idx' is the starting element of the LIS
        * (its previousIndex is -1), so we add it as well.
        */
        lis.add(arr[idx]);

        /*
        * The elements were collected while backtracking from end → start of the LIS.
        * Hence, the list is currently in reverse order.
        *
        * We reverse it to restore the correct sequence (start → end of LIS).
        */
        Collections.reverse(lis);

        return lis;
    }
}
