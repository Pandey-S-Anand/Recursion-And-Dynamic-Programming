//Naive Implementation

class Solution {
    static Boolean isSubsetSum(int arr[], int targetSum) {
        /*
        * dp[i][sum] represents:
        * "Can we form the target sum = sum using elements from index i to n-1?"
        */
        boolean[][] dp = new boolean[arr.length + 1][targetSum + 1];

        dp[arr.length][0] = true;

        for (int sum = 1; sum <= targetSum; sum++) {
            dp[arr.length][sum] = false;
        }

        for (int i = 0; i < arr.length; i++) {
            dp[i][0] = true;
        }

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int sum = 1; sum <= targetSum; sum++) {
                if (sum >= arr[i] && dp[i + 1][sum - arr[i]]) {
                    dp[i][sum] = true;
                }
                dp[i][sum] = dp[i][sum] || dp[i + 1][sum];
            }

            // Early exit: stop as soon as targetSum becomes achievable
            if (dp[i][targetSum]) {
                return true;
            }
        }

        return dp[0][targetSum];
    }
}


