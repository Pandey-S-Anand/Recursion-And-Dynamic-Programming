//Optimal implementation

class Solution {
    static Boolean isSubsetSum(int arr[], int targetSum) {
        // Since dp[i][*] depends on dp[i+1][*], we use two arrays to represent current and next rows
        boolean[] currentRow = new boolean[targetSum + 1];
        boolean[] nextRow = new boolean[targetSum + 1];

        nextRow[0] = true;

        for (int i = arr.length - 1; i >= 0; i--) {
            currentRow[0] = true;
            for (int sum = 1; sum <= targetSum; sum++) {
                if (sum >= arr[i] && nextRow[sum - arr[i]]) {
                    currentRow[sum] = true;
                }
                currentRow[sum] = currentRow[sum] || nextRow[sum];
            }

            if (currentRow[targetSum]) {
                return true;
            }

            boolean[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[targetSum];
    }
}
