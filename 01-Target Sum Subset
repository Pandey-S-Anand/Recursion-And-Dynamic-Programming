//Bruteforce Approach

class Solution {
    static Boolean isSubsetSum(int arr[], int sum) {
        // We start from index 0 and try to form the target sum
        return isSubsetSum(arr, 0, sum);
    }

    /*
    * Core Idea (Brute Force Recursion):
    * ----------------------------------
    * In subset problems, for every element we always have two choices:
    * 1. Take the current element
    * 2. Do NOT take the current element
    *
    * So for each index, we explore both possibilities recursively.
    *
    * This recursive call represents:
    * "Can we achieve the targetSum using elements from current index to end?"
    */
    private static Boolean isSubsetSum(int arr[], int index, int targetSum) {
        /*
         * Base Case 1:
         * If we have reached the end of the array,
         * we check whether we were able to form the target sum.
         *
         * If targetSum == 0 → valid subset found
         * Else → no valid subset
         */
        if (index == arr.length) {
            return targetSum == 0;
        }

        /*
         * Base Case 2:
         * If targetSum becomes 0 at any point,
         * we have successfully found a subset.
         *
         * No need to explore further.
         */
        if (targetSum == 0) {
            return true;
        }

        /*
         * Choice 1: Take the current element
         * ----------------------------------
         * We can only take the element if it does not exceed the remaining targetSum.
         *
         * If we take it:
         *   - Reduce targetSum by arr[index]
         *   - Move to next index
         *
         * If this path returns true, we immediately return true.
         *
         * Note:
         * If arr[index] > targetSum, we skip the "take" option,
         * since all elements and targetSum are positive.
         * Including it would make targetSum negative,
         * and it cannot become non-negative again.
         */
        if (targetSum >= arr[index] && isSubsetSum(arr, index + 1, targetSum - arr[index])) {
            return true;
        }

        /*
         * Choice 2: Do NOT take the current element
         * -----------------------------------------
         * Just move to the next index, targetSum remains unchanged
         */
        return isSubsetSum(arr, index + 1, targetSum);
    }
}


//Improved Approach

class Solution {
    /*
    * Memoization:
    * dp[index][targetSum] stores whether we can form targetSum
    * using elements from index → end.
    *
    * Meaning of values:
    * - null  → this state has NOT been computed yet
    * - true  → targetSum is achievable from this state
    * - false → targetSum is NOT achievable from this state
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation in future calls.
    */
    private static Boolean[][] dp;

    static Boolean isSubsetSum(int arr[], int sum) {
        dp = new Boolean[arr.length][sum + 1];
        return isSubsetSum(arr, 0, sum);
    }

    private static Boolean isSubsetSum(int arr[], int index, int targetSum) {
        if (index == arr.length) {
            return targetSum == 0;
        }

        if (targetSum == 0) {
            return true;
        }

        if (dp[index][targetSum] != null) {
            return dp[index][targetSum];
        }

        if (targetSum >= arr[index] && isSubsetSum(arr, index + 1, targetSum - arr[index])) {
            return dp[index][targetSum] = true;
        }

        return dp[index][targetSum] = isSubsetSum(arr, index + 1, targetSum);
    }
}


