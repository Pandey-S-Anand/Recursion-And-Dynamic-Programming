/*
 * Example:
 * arr = [1, 15, 7, 9, 2], k = 3
 *
 * We can create partitions of size at most 3.
 *
 * Suppose we choose:
 *
 *   [1, 15, 7] | [9, 2]
 *
 * Step 1: Partition = [1, 15, 7]
 * - max element = 15
 * - partition size = 3
 *
 * After replacement:
 *   [15, 15, 15]
 *
 * Contribution:
 *   15 × 3 = 45
 *
 * Step 2: Partition = [9, 2]
 * - max element = 9
 * - partition size = 2
 *
 * After replacement:
 *   [9, 9]
 *
 * Contribution:
 *   9 × 2 = 18
 *
 * Final transformed array:
 *   [15, 15, 15, 9, 9]
 *
 * Total sum:
 *   45 + 18 = 63
 */

//Bruteforce Approach

class Solution {
    public int maxSumAfterPartitioning(int[] arr, int k) {
        return maxSumAfterPartitioning(arr, 0, k);
    }

    private int maxSumAfterPartitioning(int[] arr, int index, int k) {
        // Base case: all elements have been partitioned
        if (index == arr.length) {
            return 0;
        }

        // Tracks the maximum element in the current partition
        int maxInCurrentPartition = Integer.MIN_VALUE;

        // Stores the maximum sum obtainable from all valid partition choices
        int maxPartitionSum = Integer.MIN_VALUE;

        // Try all possible partition sizes from 1 to k
        for (int partitionSize = 1; partitionSize <= k; partitionSize++) {
            // Partition exceeds array bounds
            if (index + partitionSize > arr.length) {
                break;
            }

            // Expand the current partition and update its maximum element
            maxInCurrentPartition = Math.max(maxInCurrentPartition, arr[index + partitionSize - 1]);

            /*
            * Contribution of the current partition:
            * - Every element in this partition becomes equal to
            *   the maximum element in the partition.
            *
            * - Hence, contribution =
            *     max element in partition × partition size
            *
            * - Add the maximum sum obtainable from the remaining array recursively.
            */
            int totalSumWithCurrentPartition = (maxInCurrentPartition * partitionSize) + maxSumAfterPartitioning(arr, index + partitionSize, k);

            // Track the best answer among all partition choices
            maxPartitionSum = Math.max(maxPartitionSum, totalSumWithCurrentPartition);
        }

        return maxPartitionSum;
    }
}



//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[index] stores the maximum sum obtainable starting from index 'index'
    * after partitioning the remaining array.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum sum obtainable from index → end
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[index]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int maxSumAfterPartitioning(int[] arr, int k) {
        dp = new Integer[arr.length];
        return maxSumAfterPartitioning(arr, 0, k);
    }

    private int maxSumAfterPartitioning(int[] arr, int index, int k) {
        if (index == arr.length) {
            return 0;
        }

        if (dp[index] != null) {
            return dp[index];
        }

        int maxInCurrentPartition = Integer.MIN_VALUE;
        int maxPartitionSum = Integer.MIN_VALUE;

        for (int partitionSize = 1; partitionSize <= k; partitionSize++) {
            if (index + partitionSize > arr.length) {
                break;
            }

            maxInCurrentPartition = Math.max(maxInCurrentPartition, arr[index + partitionSize - 1]);

            int totalSumWithCurrentPartition = (maxInCurrentPartition * partitionSize) + maxSumAfterPartitioning(arr, index + partitionSize, k);

            maxPartitionSum = Math.max(maxPartitionSum, totalSumWithCurrentPartition);
        }

        return dp[index] = maxPartitionSum;
    }
}



//Optimal Approach

class Solution {
    public int maxSumAfterPartitioning(int[] arr, int k) {
        /*
        * dp[i] represents the maximum sum obtainable starting from index 'i'
        * after partitioning the remaining array.
        */
        int[] dp = new int[arr.length + 1];

        dp[arr.length] = 0;

        for (int i = arr.length - 1; i >= 0; i--) {
            int maxInCurrentPartition = Integer.MIN_VALUE;
            int maxPartitionSum = Integer.MIN_VALUE;

            for (int partitionSize = 1; partitionSize <= k; partitionSize++) {
                if (i + partitionSize > arr.length) {
                    break;
                }

                maxInCurrentPartition = Math.max(maxInCurrentPartition, arr[i + partitionSize - 1]);

                int totalSumWithCurrentPartition = (maxInCurrentPartition * partitionSize) + dp[i + partitionSize];

                maxPartitionSum = Math.max(maxPartitionSum, totalSumWithCurrentPartition);
            }

            dp[i] = maxPartitionSum;
        }

        return dp[0];
    }
}

