/*
 * Climbing from the ground to the nth stair is mathematically equivalent 
 * to descending from the nth stair to the ground. If you reverse the process, 
 * the number of ways to reach the nth stair from the ground is the same as 
 * the number of ways to descend from the nth stair to the ground.
 * 
 * - Climbing from the nth stair to the ground can be viewed as a backward recursion.
 * - Climbing from the ground to the nth stair can be viewed as a forward recursion.
 */

//Bruteforce Approach

class Solution {
    public int climbStairs(int n) {
        // We start from stair 0, which represents the ground.
        return climbStairs(0, n);
    }

    public int climbStairs(int currentStair, int destinationStair) {
        // Base case: If we reach the destination stair, there is exactly one valid way — staying on it.
        if (currentStair == destinationStair) {
            return 1;
        }

        // If we exceed the destination stair, this path is invalid, so return 0 ways.
        if (currentStair > destinationStair) {
            return 0;
        }

        /*
        * Recursive Case:
        *
        * At any stair 'currentStair', we have two independent choices:
        *
        * 1. Take 1 step → move to (currentStair + 1)
        *    → number of ways = climbStairs(currentStair + 1)
        *
        *    Meaning:
        *    - After taking 1 step, we land on (currentStair + 1).
        *    - Now the problem reduces to:
        *        "In how many ways can we reach the destination from (currentStair + 1)?"
        *    - climbStairs(currentStair + 1) returns exactly that count.
        *    - Each of those paths can be extended by adding this 1-step at the beginning.
        *
        *
        * 2. Take 2 steps → move to (currentStair + 2)
        *    → number of ways = climbStairs(currentStair + 2)
        *
        *    Meaning:
        *    - After taking 2 steps, we land on (currentStair + 2).
        *    - Now the problem reduces to:
        *        "In how many ways can we reach the destination from (currentStair + 2)?"
        *    - climbStairs(currentStair + 2) returns that count.
        *    - Each of those paths can be extended by adding this 2-step at the beginning.
        *
        *
        * Why do we ADD and not MULTIPLY?
        *
        * - These two choices represent DIFFERENT paths (mutually exclusive options).
        * - A path either starts with a 1-step OR a 2-step — not both together.
        *
        * - Addition is used when counting total ways across different choices.
        * - Multiplication is used when choices are dependent and combined together
        *   (which is NOT the case here).
        *
        * So:
        *   totalWays = ways via 1-step + ways via 2-step
        */

        int waysFromNextStair = climbStairs(currentStair + 1, destinationStair);
        int waysFromNextNextStair = climbStairs(currentStair + 2, destinationStair);

        return waysFromNextStair + waysFromNextNextStair;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[currentStair] stores the number of ways to reach the destination
    * from the given currentStair.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → number of ways to reach destination from currentStair
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute it and store it in dp[currentStair]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    private int climbStairs(int n) {
        dp = new Integer[n];
        return climbStairs(0, n);
    }

    public int climbStairs(int currentStair, int destinationStair) {
        if (currentStair == destinationStair) {
            return 1;
        }

        if (currentStair > destinationStair) {
            return 0;
        }

        if (dp[currentStair] != null) {
            return dp[currentStair];
        }

        int wayFromNextStair = climbStairs(currentStair + 1, destinationStair);
        int wayFromNextNextStair = climbStairs(currentStair + 2, destinationStair);

        return dp[currentStair] = wayFromNextStair + wayFromNextNextStair;
    }
}


//Optimal Approach

class Solution {
    public int climbStairs(int n) {
        //dp[stair] represents the number of ways to reach the destination from the given stair.
        int[] dp = new int[n + 2];

        dp[n] = 1; // From destination stair, there is exactly one way (stay there)
        dp[n + 1] = 0; //Beyond destination, no valid path exists

        for (int stair = n - 1; stair >= 0; stair--) {
            int wayFromNextStair = dp[stair + 1];
            int wayFromNextNextStair = dp[stair + 2];
            dp[stair] = wayFromNextStair + wayFromNextNextStair;
        }
        //dp[0] gives the total number of ways starting from ground floor
        return dp[0];
    }
}
