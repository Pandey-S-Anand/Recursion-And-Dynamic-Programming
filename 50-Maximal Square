/*
 * Intuition:
 *
 * - We iterate over every cell in the matrix.
 * - For each cell that contains '1', we treat it as the top-left corner
 *   of a square and try to find the largest square (all 1s) that can be
 *   formed starting from that cell.
 *
 * - The helper function maxSquareSizeFromCell(row, col) returns:
 *     → the size of the largest square submatrix (all 1s)
 *       having (row, col) as its top-left corner.
 *
 * - Since it is a square, all sides are equal,
 *   so this size is also the side length of the largest square
 *   with (row, col) as its top-left corner.
 *
 * - Once we know the side length, we compute the area:
 *
 *       area = side × side
 *
 * - We keep track of the maximum area across all such starting points.
 */

//Bruteforce Approach

class Solution {
    public int maximalSquare(char[][] matrix) {
        int maxSquareArea = 0;
        for (int row = 0; row < matrix.length; row++) {
            for (int col = 0; col < matrix[0].length; col++) {
                if (matrix[row][col] == '1') {
                    int maxSideFromCurrentCell = maxSquareSizeFromCell(matrix, row, col);
                    int areaFromCurrentCell = maxSideFromCurrentCell * maxSideFromCurrentCell;
                    maxSquareArea = Math.max(maxSquareArea, areaFromCurrentCell);
                }
            }
        }

        return maxSquareArea;
    }

    private int maxSquareSizeFromCell(char[][] matrix, int row, int col) {
        if (row == matrix.length || col == matrix[0].length) {
            return 0;
        }

        if (matrix[row][col] == '0') {
            return 0;
        }

        int rightSquareSize = maxSquareSizeFromCell(matrix, row, col + 1);
        int downSquareSize = maxSquareSizeFromCell(matrix, row + 1, col);
        int diagonalSquareSize = maxSquareSizeFromCell(matrix, row + 1, col + 1);

        return 1 + Math.min(rightSquareSize, Math.min(downSquareSize, diagonalSquareSize));
    }
}


//Improved Approach

class Solution {
    /*
    * Memoization:
    * dp[row][col] stores the side length of the largest square submatrix (all 1s)
    * where (row, col) acts as the top-left corner.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum side length of square with (row, col) as top-left corner
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int maximalSquare(char[][] matrix) {
        dp = new Integer[matrix.length + 1][matrix[0].length + 1];
        int maxSquareArea = 0;

        for (int row = 0; row < matrix.length; row++) {
            for (int col = 0; col < matrix[0].length; col++) {
                if (matrix[row][col] == '1') {
                    int maxSideFromCurrentCell = maxSquareSizeFromCell(matrix, row, col);
                    int areaFromCurrentCell = maxSideFromCurrentCell * maxSideFromCurrentCell;
                    maxSquareArea = Math.max(maxSquareArea, areaFromCurrentCell);
                }
            }
        }

        return maxSquareArea;
    }

    private int maxSquareSizeFromCell(char[][] matrix, int row, int col) {
        if (row == matrix.length || col == matrix[0].length) {
            return 0;
        }

        if (matrix[row][col] == '0') {
            return 0;
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int rightSquareSize = maxSquareSizeFromCell(matrix, row, col + 1);
        int downSquareSize = maxSquareSizeFromCell(matrix, row + 1, col);
        int diagonalSquareSize = maxSquareSizeFromCell(matrix, row + 1, col + 1);

        return dp[row][col] = 1 + Math.min(rightSquareSize, Math.min(downSquareSize, diagonalSquareSize));
    }
}


