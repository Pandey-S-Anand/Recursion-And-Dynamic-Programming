//Naive Implementation 

class Solution {
    public int maximalSquare(char[][] matrix) {
        /*
        * dp[row][col] represents the side length of the largest square submatrix (all 1s)
        * where (row, col) is the top-left corner of that square.
        */
        int[][] dp = new int[matrix.length + 1][matrix[0].length + 1];
        int maxSquareArea = 0;

        for (int col = 0; col < matrix[0].length; col++) {
            dp[matrix.length][col] = 0;
        }

        for (int row = 0; row < matrix.length; row++) {
            dp[row][matrix[0].length] = 0;
        }

        for (int row = matrix.length - 1; row >= 0; row--) {
            for (int col = matrix[0].length - 1; col >= 0; col--) {
                if (matrix[row][col] == '1') {
                    int rightSquareSize = dp[row][col + 1];
                    int downSquareSize = dp[row + 1][col];
                    int diagonalSquareSize = dp[row + 1][col + 1];
                    int maxSideFromCurrentCell = 1 + Math.min(rightSquareSize, Math.min(downSquareSize, diagonalSquareSize));
                    dp[row][col] = maxSideFromCurrentCell;
                    int areaFromCurrentCell = maxSideFromCurrentCell * maxSideFromCurrentCell;
                    maxSquareArea = Math.max(maxSquareArea, areaFromCurrentCell);
                } else {
                    dp[row][col] = 0;
                }
            }
        }

        return maxSquareArea;
    }
}


//Better Implementation 

class Solution {
    public int maximalSquare(char[][] matrix) {
        int[][] dp = new int[matrix.length + 1][matrix[0].length + 1];
        int maxSquareArea = 0;

        for (int row = matrix.length - 1; row >= 0; row--) {
            for (int col = matrix[0].length - 1; col >= 0; col--) {
                if (matrix[row][col] == '1') {
                    dp[row][col] = 1 + Math.min(dp[row][col + 1], Math.min(dp[row + 1][col], dp[row + 1][col + 1]));
                    int areaFromCurrentCell = dp[row][col] * dp[row][col];
                    maxSquareArea = Math.max(maxSquareArea, areaFromCurrentCell);
                }
            }
        }

        return maxSquareArea;
    }
}


//Optimal implementation

class Solution {
    public int maximalSquare(char[][] matrix) {
        /*
        * Space Optimization:
        *
        * Instead of using a 2D dp array, we use two 1D arrays:
        * - currentRow → represents dp[row][*]
        * - nextRow    → represents dp[row + 1][*]
        *
        * Why this works:
        * - Each state dp[row][col] depends only on:
        *     → right    → currentRow[col + 1]
        *     → down     → nextRow[col]
        *     → diagonal → nextRow[col + 1]
        *
        * - So, while processing a row, we only need:
        *     → values from the current row (for right)
        *     → values from the next row (for down & diagonal)
        *
        * - Hence, storing the entire 2D dp table is unnecessary.
        *
        * This reduces space complexity from O(m * n) → O(n)
        * while keeping the same logic intact.
        */
        int[] currentRow = new int[matrix[0].length + 1];
        int[] nextRow = new int[matrix[0].length + 1];
        int maxSquareArea = 0;

        for (int row = matrix.length - 1; row >= 0; row--) {
            for (int col = matrix[0].length - 1; col >= 0; col--) {
                if (matrix[row][col] == '1') {
                    currentRow[col] = 1 + Math.min(currentRow[col + 1], Math.min(nextRow[col], nextRow[col + 1]));
                    int areaFromCurrentCell = currentRow[col] * currentRow[col];
                    maxSquareArea = Math.max(maxSquareArea, areaFromCurrentCell);
                } else {
                    currentRow[col] = 0;
                }
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return maxSquareArea;
    }
}
