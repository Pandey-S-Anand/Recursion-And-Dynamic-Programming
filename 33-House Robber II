//Bruteforce Approach

class Solution {
    public int rob(int[] arr) {
        if (arr.length == 1) {
            return arr[0];
        }

        /*
         * Since the houses are arranged in a circle, we can't rob both the first
         * and the last house. Therefore, we split the problem into two cases:
         * 1. Rob houses from the first house to the second-to-last house (index 0 to arr.length - 2)
         * 2. Rob houses from the second house to the last house (index 1 to arr.length - 1)
         * 
         * The result will be the maximum amount robbed from these two cases.
         */
        return Math.max(rob(arr, 0, arr.length - 2), rob(arr, 1, arr.length - 1));
    }

    private int rob(int[] arr, int currentIndex, int lastIndex) {
        // Base case: When currentIndex > lastIndex, no houses are left to consider, so return 0.
        if (currentIndex > lastIndex) {
            return 0;
        }

        // Option 1: Rob the current house (arr[currentIndex]) and move to the next house that can be robbed, i.e., currentIndex + 2
        int rob = arr[currentIndex] + rob(arr, currentIndex + 2, lastIndex);
        // Option 2: Skip the current house and move to the next house, i.e., currentIndex + 1
        int notRob = rob(arr, currentIndex + 1, lastIndex);

        // Return the maximum of robbing the current house or skipping it
        return Math.max(rob, notRob);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[currentHouse] stores the maximum money that can be robbed
    * starting from the given currentHouse (within the allowed range).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum profit from currentHouse to lastHouse
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[currentHouse]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int rob(int[] arr) {
        if (arr.length == 1) {
            return arr[0];
        }

        dp = new Integer[arr.length];

        int case1Profit = rob(arr, 0, arr.length - 2);
        Arrays.fill(dp, null);
        int case2Profit = rob(arr, 1, arr.length - 1);

        return Math.max(case1Profit, case2Profit);
    }

    private int rob(int[] arr, int currentIndex, int lastIndex) {
        if (currentIndex > lastIndex) {
            return 0;
        }

        if (dp[currentIndex] != null) {
            return dp[currentIndex];
        }

        int rob = arr[currentIndex] + rob(arr, currentIndex + 2, lastIndex);
        int notRob = rob(arr, currentIndex + 1, lastIndex);

        return dp[currentIndex] = Math.max(rob, notRob);
    }
}


