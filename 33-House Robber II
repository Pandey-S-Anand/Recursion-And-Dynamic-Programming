//Naive implementation

class Solution {
    public int rob(int[] arr) {
        if (arr.length == 1) {
            return arr[0];
        }

        return Math.max(rob(arr, 0, arr.length - 2), rob(arr, 1, arr.length - 1));
    }

    private int rob(int[] arr, int start, int end) {
        int n = end + 1;

        //dp[i] stores the maximum money that can be robbed starting from index i.
        int[] dp = new int[n + 2];

        // Base case: dp[n] and dp[n+1] represent positions beyond the last house, so no money can be robbed → both are initialized to 0.
        dp[n] = dp[n + 1] = 0;

        for (int i = end; i >= start; i--) {
            int rob = arr[i] + dp[i + 2];
            int notRob = dp[i + 1];
            dp[i] = Math.max(rob, notRob);
        }

        return dp[start];
    }
}


//Optimal implementation

class Solution {
    public int rob(int[] arr) {
        if (arr.length == 1) {
            return arr[0];
        }

        return Math.max(rob(arr, 0, arr.length - 2), rob(arr, 1, arr.length - 1));
    }

    private int rob(int[] arr, int start, int end) {
        /*
        * Space Optimization:
        *
        * - In the tabulation approach, dp[i] depends only on:
        *     → dp[i + 1] (next)
        *     → dp[i + 2] (nextNext)
        *
        * - Since only the next two states are required, we can avoid using
        *   the entire dp array and instead use two variables:
        *
        *     → nextProfit     = dp[i + 1]
        *     → nextNextProfit = dp[i + 2]
        */
        int nextProfit = 0, nextNextProfit = 0;

        for (int i = end; i >= start; i--) {
            int rob = arr[i] + nextNextProfit;
            int notRob = nextProfit;
            int currentProfit = Math.max(rob, notRob);

            int temp = nextProfit;
            nextProfit = currentProfit;
            nextNextProfit = temp;
        }

        return nextProfit;
    }
}
