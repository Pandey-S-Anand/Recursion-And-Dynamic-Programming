/*
 * Logic:
 *
 * We need to partition the array into two subsets: S1 and S2
 * such that the difference of their sums equals D.
 *
 * Let:
 * sum(S1) = sum1
 * sum(S2) = sum2
 * total sum of array = S
 *
 * Given:
 *      sum1 - sum2 = D          ...(1)
 *      sum1 + sum2 = S          ...(2)
 *
 * From (2):
 *      sum2 = S - sum1
 *
 * Substitute in (1):
 *      sum1 - (S - sum1) = D
 *      2 * sum1 - S = D
 *      2 * sum1 = S + D
 *      sum1 = (S + D) / 2
 *
 * ------------------------------------------------------------
 *
 * Instead of explicitly forming two subsets (S1, S2),
 * we only choose one subset S1.
 * The remaining elements automatically form S2.
 *
 * For every subset S1 such that:
 *      sum(S1) = (S + D) / 2
 *
 * the remaining elements form S2 with:
 *      sum(S2) = S - sum(S1)
 *
 * Now verify the condition:
 *
 *      sum(S1) - sum(S2)
 *    = sum1 - (S - sum1)
 *    = 2 * sum1 - S
 *
 * Since:
 *      2 * sum1 = S + D
 *
 * Therefore:
 *      2 * sum1 - S = (S + D) - S = D
 *
 * Hence:
 *      sum(S1) - sum(S2) = D
 *
 * ------------------------------------------------------------
 *
 * Therefore, every subset with sum = (S + D)/2
 * corresponds to a valid partition (S1, S2)
 * satisfying the required condition.
 *
 * So, counting subsets with sum = (S + D)/2
 * gives the count of partitions where:
 *      sum(S1) - sum(S2) = D
 */

//Bruteforce Approach

class Solution {
    public int countPartitions(int[] arr, int d) {
        int arrSum = Arrays.stream(arr).sum();

        // If arrSum < d, no valid partition can satisfy sum(S1) - sum(S2) = d
        if (arrSum < d) {
            return 0;
        }

        /*
        * If (arrSum + d) is odd,
        * it is not possible to divide the array into two subsets with integer sums.
        */
        if ((arrSum + d) % 2 != 0) {
            return 0;
        }

        return countSubsetsWithTargetSum(arr, 0, (arrSum + d) / 2);
    }

    /*
    * This recursive call represents:
    * "Number of subsets we can form using elements from index → end
    * such that their sum equals target."
    */
    private int countSubsetsWithTargetSum(int[] arr, int index, int targetSum) {
        /*
         * Base Case:
         * If we have reached the end of the array,
         * check whether the remaining target is 0.
         *
         * If target == 0 → one valid subset found → return 1
         * Else → no valid subset → return 0
         */
        if (index == arr.length) {
            return targetSum == 0 ? 1 : 0;
        }

        /*
         * Since all elements and target are non-negative,
         * once target becomes negative, it cannot become 0 again.
         * Hence, we only consider the "take" option when
         * arr[index] <= target.
         */
        int count = 0;

        // Option 1: Take the current element
        if (targetSum >= arr[index]) {
            count += countSubsetsWithTargetSum(arr, index + 1, targetSum - arr[index]);
        }

        // Option 2: Do not take the current element
        count += countSubsetsWithTargetSum(arr, index + 1, targetSum);

        return count;
    }
}


//Improved Approach

class Solution {
    /*
    * Memoization:
    * dp[index][targetSum] stores the number of subsets
    * that can be formed using elements from index → end
    * such that their sum equals targetSum.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → number of valid subsets for this state
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation in future calls.
    */
    private Integer[][] dp;

    public int countPartitions(int[] arr, int d) {
        int arrSum = Arrays.stream(arr).sum();

        if (arrSum < d) {
            return 0;
        }

        if ((arrSum + d) % 2 != 0) {
            return 0;
        }

        int targetSum = (arrSum + d) / 2;

        dp = new Integer[arr.length][targetSum + 1];

        return countSubsetsWithTargetSum(arr, 0, targetSum);
    }

    private int countSubsetsWithTargetSum(int[] arr, int index, int targetSum) {
        if (index == arr.length) {
            return targetSum == 0 ? 1 : 0;
        }

        if (dp[index][targetSum] != null) {
            return dp[index][targetSum];
        }

        int count = 0;

        if (targetSum >= arr[index]) {
            count += countSubsetsWithTargetSum(arr, index + 1, targetSum - arr[index]);
        }

        count += countSubsetsWithTargetSum(arr, index + 1, targetSum);

        return dp[index][targetSum] = count;
    }
}


