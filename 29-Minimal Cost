//Bruteforce Approach

class Solution {
    public int minimizeCost(int k, int arr[]) {
       return minCost(0, arr, k);
    }
    
    private int minCost(int currentStone, int[] arr, int k) {
        // Base case : If we have reached the destination stair, no cost is required further.
        if (currentStone == arr.length - 1) {
            return 0;
        }
        
        // Initialize the minimum cost for the current stair.
        int minCost=Integer.MAX_VALUE;
        
        // Try jumps of all possible lengths from 1 to k (inclusive).
        for(int jumpSize=1;jumpSize<=k;jumpSize++){
            // If the jump goes beyond the destinationStair stair i.e arr.length - 1, break the loop (invalid jump).
            if((currentStone+jumpSize)>=arr.length){
               break;   
            }
            
            int cost = Math.abs(arr[currentStone+jumpSize] - arr[currentStone]) + minCost(currentStone+jumpSize, arr, k);
            minCost=Math.min(minCost, cost);
        }

        return minCost;
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[currentStone] stores the minimum energy required to reach
    * the last stone from the given currentStone.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum cost to reach the last stone from currentStone
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute it and store it in dp[currentStone]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int minimizeCost(int k, int arr[]) {
        dp = new Integer[arr.length];
        return minCost(0, arr, k);
    }

    private int minCost(int currentStone, int[] arr, int k) {
        if (currentStone == arr.length - 1) {
            return 0;
        }

        if (dp[currentStone] != null) {
            return dp[currentStone];
        }

        int minCost = Integer.MAX_VALUE;

        for (int jumpSize = 1; jumpSize <= k; jumpSize++) {
            if ((currentStone + jumpSize) >= arr.length) {
                break;
            }

            int cost = Math.abs(arr[currentStone + jumpSize] - arr[currentStone]) + minCost(currentStone + jumpSize, arr, k);
            minCost = Math.min(minCost, cost);
        }

        return dp[currentStone] = minCost;
    }
}


//Optimal Approach

class Solution {
    public int minimizeCost(int k, int arr[]) {
        // dp[i] represents the minimum energy consumed to reach last stair from i th stair
        int[] dp = new int[arr.length];

        dp[arr.length - 1] = 0;

        for (int stone = arr.length - 2; stone >= 0; stone--) {
            int minCost = Integer.MAX_VALUE;

            for (int jumpSize = 1; jumpSize <= k; jumpSize++) {
                if ((stone + jumpSize) >= arr.length) {
                    break;
                }

                int cost = Math.abs(arr[stone + jumpSize] - arr[stone]) + dp[stone + jumpSize];
                minCost = Math.min(minCost, cost);
            }

            dp[stone] = minCost;
        }

        return dp[0];
    }
}
