//Bruteforce Approach

class Solution {
    public int minPathSum(int[][] grid) {
        /*
        * Note:
        * - The destination is always reachable because:
        *     → We can only move right or down
        *     → There are no obstacles in the grid
        */
        return minPathSum(grid, 0, 0, grid.length, grid[0].length);
    }

    private int minPathSum(int[][] grid, int row, int col, int m, int n) {
        // Base Case: If we have reached the bottom-right corner of the grid (i.e grid[m-1][n-1]), return its value
        if (row == m - 1 && col == n - 1) {
            return grid[row][col];
        }

        // Out of bounds → invalid path
        if (row == m || col == n) {
            return Integer.MAX_VALUE;
        }

        // Explore both possible moves
        int pathsMovingRight = minPathSum(grid, row, col + 1, m, n);
        int pathsMovingDown = minPathSum(grid, row + 1, col, m, n);

        /*
        * Choose the minimum path:
        * - From current cell, we take the cheaper path between right and down
        * - Add current cell value to that minimum
        */
        return grid[row][col] + Math.min(pathsMovingRight, pathsMovingDown);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[row][col] stores the minimum path sum required to reach
    * the destination (bottom-right cell) starting from cell (row, col).
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum cost to reach destination from (row, col)
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[row][col]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int minPathSum(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        dp = new Integer[m][n];

        return minPathSum(grid, 0, 0, m, n);
    }

    private int minPathSum(int[][] grid, int row, int col, int m, int n) {
        if (row == m - 1 && col == n - 1) {
            return grid[row][col];
        }

        if (row == m || col == n) {
            return Integer.MAX_VALUE;
        }

        if (dp[row][col] != null) {
            return dp[row][col];
        }

        int pathsMovingRight = minPathSum(grid, row, col + 1, m, n);
        int pathsMovingDown = minPathSum(grid, row + 1, col, m, n);

        return dp[row][col] = grid[row][col] + Math.min(pathsMovingRight, pathsMovingDown);
    }
}


