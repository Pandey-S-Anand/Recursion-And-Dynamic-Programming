//Naive implementation

class Solution {
    public int minPathSum(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        /*
        * dp[row][col] represents the minimum path sum required to reach
        * the destination (bottom-right cell) starting from cell (row, col).
        */
        int[][] dp = new int[m + 1][n + 1];

        for (int col = 0; col < n; col++) {
            dp[m][col] = Integer.MAX_VALUE;
        }

        for (int row = 0; row < m; row++) {
            dp[row][n] = Integer.MAX_VALUE;
        }

        for (int row = m - 1; row >= 0; row--) {
            for (int col = n - 1; col >= 0; col--) {
                if (row == m - 1 && col == n - 1) {
                    dp[row][col] = grid[row][col];
                } else {
                    int pathsMovingRight = dp[row][col + 1];
                    int pathsMovingDown = dp[row + 1][col];

                    dp[row][col] = grid[row][col] + Math.min(pathsMovingRight, pathsMovingDown);
                }
            }
        }

        return dp[0][0];
    }
}


//Better implementation

class Solution {
    public int minPathSum(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        int[][] dp = new int[m][n];

        dp[m - 1][n - 1] = grid[m - 1][n - 1];

        for (int col = n - 2; col >= 0; col--) {
            dp[m - 1][col] = grid[m - 1][col] + dp[m - 1][col + 1];
        }

        for (int row = m - 2; row >= 0; row--) {
            dp[row][n - 1] = grid[row][n - 1] + dp[row + 1][n - 1];
        }

        for (int row = m - 2; row >= 0; row--) {
            for (int col = n - 2; col >= 0; col--) {
                dp[row][col] = grid[row][col] + Math.min(dp[row][col + 1], dp[row + 1][col]);
            }
        }

        return dp[0][0];
    }
}


//Optimal implementation

class Solution {
    public int minPathSum(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;

        /*
        * Space Optimization (from 2D → 1D):
        *
        * - In the 2D DP approach, dp[row][col] depends only on:
        *     → dp[row][col + 1]   (right cell in the same row)
        *     → dp[row + 1][col]   (same column in the next row)
        *
        * - Since each state depends only on the current row and the next row,
        *   we can avoid storing the entire 2D dp array.
        *
        * - Instead, we use two 1D arrays:
        *     → currentRow[col] → represents dp[row][col]
        *     → nextRow[col]    → represents dp[row + 1][col]
        */
        int[] currentRow = new int[n];
        int[] nextRow = new int[n];

        nextRow[n - 1] = grid[m - 1][n - 1];

        for (int col = n - 2; col >= 0; col--) {
            nextRow[col] = grid[m - 1][col] + nextRow[col + 1];
        }

        for (int row = m - 2; row >= 0; row--) {
            currentRow[n - 1] = grid[row][n - 1] + nextRow[n - 1];

            for (int col = n - 2; col >= 0; col--) {
                currentRow[col] = grid[row][col] + Math.min(currentRow[col + 1], nextRow[col]);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0];
    }
}
