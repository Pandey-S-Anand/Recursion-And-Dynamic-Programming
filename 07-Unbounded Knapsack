//Naive Implementation

class Solution {
    public int knapSack(int value[], int weight[], int maxCapacity) {
        /*
        * dp[i][capacity] represents:
        * "Maximum value that can be obtained using items from index i to n-1
        * with remaining capacity = capacity."
        *
        * Note:
        * Since this is Unbounded Knapsack, when we take an item,
        * we stay at the same index (i) to allow multiple selections.
        */
        int[][] dp = new int[weight.length + 1][maxCapacity + 1];

        for (int capacity = 0; capacity <= maxCapacity; capacity++) {
            dp[weight.length][capacity] = 0;
        }

        for (int i = 0; i <= weight.length; i++) {
            dp[i][0] = 0;
        }

        for (int i = weight.length - 1; i >= 0; i--) {
            for (int capacity = 1; capacity <= maxCapacity; capacity++) {
                if (weight[i] <= capacity) {
                    dp[i][capacity] = value[i] + dp[i][capacity - weight[i]];
                }

                dp[i][capacity] = Math.max(dp[i][capacity], dp[i + 1][capacity]);
            }
        }

        return dp[0][maxCapacity];
    }
}

