//Bruteforce Approach

/**
 * Why Greedy does NOT work for Unbounded (Infinite) Knapsack:
 *
 * In the Unbounded Knapsack problem, each item can either be:
 * - taken multiple times (unlimited supply), or
 * - completely excluded
 *
 * Unlike Fractional Knapsack, we cannot take a fraction of an item.
 *
 * ------------------------------------------------------------
 *
 * Greedy strategies typically try to make a locally optimal choice, such as:
 * - Picking the item with maximum value
 * - Picking the item with minimum weight
 * - Picking the item with the highest value/weight ratio
 *
 * However, these local decisions do NOT guarantee a globally optimal solution.
 *
 * ------------------------------------------------------------
 *
 * Counter Example:
 *
 * Capacity W = 13
 *
 * Item    Weight   Value   Value/Weight
 * ------------------------------------
 * A       5        11      2.2
 * B       4        8       2.0
 * C       3        7       2.3  ← best ratio
 *
 * Greedy (based on value/weight ratio):
 * - Pick C repeatedly (best ratio = 2.3)
 *   → C + C + C + C = value = 7 * 4 = 28
 *   → Remaining capacity = 1 (cannot be used)
 *
 * Total value = 28
 *
 * ------------------------------------------------------------
 *
 * Optimal Solution:
 *
 * - Pick A twice → value = 11 * 2 = 22
 * - Pick C once  → value = 7
 *
 * Total value = 22 + 7 = 29 (better than 28)
 *
 * ------------------------------------------------------------
 *
 * Key Insight:
 *
 * Even if we repeatedly pick the item with the best value/weight ratio,
 * it may lead to inefficient use of capacity and block better combinations
 * of other items.
 *
 * Greedy fails because:
 * - It makes locally optimal choices, which do not guarantee a globally optimal solution
 * - It ignores future combinations
 * - It may lead to suboptimal utilization of remaining capacity
 *
 * ------------------------------------------------------------
 *
 * Conclusion:
 *
 * The problem lacks the greedy-choice property.
 * Therefore, we must explore all possibilities (take / not take),
 * which leads to a Dynamic Programming solution.
 */
class Solution {
    public int knapSack(int value[], int weight[], int maxCapacity) {
        /*
        * This recursive call represents:
        * "Maximum value we can obtain using items from index → end
        * with the remaining capacity = maxCapacity."
        */
        return knapSack(value, weight, 0, maxCapacity);
    }

    private int knapSack(int[] value, int[] weight, int index, int maxCapacity) {
        /*
         * Base Cases:
         * 1. If remaining capacity becomes 0 → no more items can be added → return 0
         * 2. If all items are considered (index == n) → no items left → return 0
         */
        if (maxCapacity == 0 || index == weight.length) {
            return 0;
        }

        int take = 0;

        /*
         * Option 1: Take the current item
         * We can take it only if its weight ≤ remaining capacity.
         * Since this is Unbounded Knapsack, we stay at the same index
         * to allow multiple selections of the same item.
         */
        if (weight[index] <= maxCapacity) {
            take = value[index] + knapSack(value, weight, index, maxCapacity - weight[index]);
        }

        /*
         * Option 2: Do NOT take the current item
         * Move to the next index and explore other items.
         */
        int notTake = knapSack(value, weight, index + 1, maxCapacity);

        // Return the maximum value between taking and not taking the current item.
        return Math.max(take, notTake);
    }
}


//Improved Approach

/*
 * Memoization:
 * dp[index][maxCapacity] stores the maximum value that can be obtained
 * using items from index → end with remaining capacity = maxCapacity.
 *
 * Meaning of values:
 * - null  → this state has NOT been computed yet
 * - value → maximum achievable value for this state
 *
 * If a state is already computed, return it directly.
 * Otherwise, compute the result and store it in dp
 * to avoid recomputation of overlapping subproblems.
 */
class Solution {
    private Integer[][] dp;

    public int knapSack(int value[], int weight[], int maxCapacity) {
        dp = new Integer[weight.length][maxCapacity + 1];
        return knapSack(value, weight, 0, maxCapacity);
    }

    private int knapSack(int[] value, int[] weight, int index, int maxCapacity) {
        if (maxCapacity == 0 || index == weight.length) {
            return 0;
        }

        if (dp[index][maxCapacity] != null) {
            return dp[index][maxCapacity];
        }

        int take = 0;

        if (weight[index] <= maxCapacity) {
            take = value[index] + knapSack(value, weight, index, maxCapacity - weight[index]);
        }

        int notTake = knapSack(value, weight, index + 1, maxCapacity);

        return dp[index][maxCapacity] = Math.max(take, notTake);
    }
}


