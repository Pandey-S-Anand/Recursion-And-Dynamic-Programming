//Optimal implementation

class Solution {
    public int knapSack(int value[], int weight[], int maxCapacity) {
        int[] currentRow = new int[maxCapacity + 1];
        int[] nextRow = new int[maxCapacity + 1];

        for (int i = weight.length - 1; i >= 0; i--) {
            for (int capacity = 1; capacity <= maxCapacity; capacity++) {
                if (weight[i] <= capacity) {
                    currentRow[capacity] = value[i] + currentRow[capacity - weight[i]];
                }

                currentRow[capacity] = Math.max(currentRow[capacity], nextRow[capacity]);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[maxCapacity];
    }
}
