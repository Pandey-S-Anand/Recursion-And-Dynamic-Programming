//Bruteforce Approach

class Solution {
    public int minCost(int n, int[] cuts) {
        /*
        * Why sorting cuts is necessary:
        *
        * - Each cut divides the stick into smaller segments.
        *
        * - For any segment [startStick, endStick], we should only consider
        *   cuts that lie within this range.
        *
        * - Sorting ensures cuts are in increasing order, so every cut naturally
        *   falls within the correct segment and results in valid left and right splits:
        *     → left  = [startStick, cuts[k]]
        *     → right = [cuts[k], endStick]
        *
        * - Without sorting:
        *     → we may pick a cut outside the current segment
        *     → leading to invalid splits and incorrect results
        *
        * Example:
        * cuts = [4, 1, 3], n = 7
        *
        * After sorting → [1, 3, 4] → all cuts fall within valid segments
        * Without sorting → trying cut = 1 inside [4, 7] is invalid
        *
        * Hence, sorting ensures correct segmentation and valid recursion.
        */
        Arrays.sort(cuts);
        return calculateMinCost(cuts, 0, n, 0, cuts.length - 1);
    }

    private int calculateMinCost(int[] cuts, int startStick, int endStick, int leftIndex, int rightIndex) {
        // Base case: If there are no cuts to make in the current segment (i.e., no cuts left between the start stick and end stick), return 0
        if (leftIndex > rightIndex) {
            return 0;
        }

        int minCost = Integer.MAX_VALUE;
        // Try each cut between leftIndex and rightIndex
        for (int partition = leftIndex; partition <= rightIndex; partition++) {
            // Calculate the cost of cutting at cuts[i] and recursively solve for the left and right segments to get the minimum cost in both the halves
            int leftCost = calculateMinCost(cuts, startStick, cuts[partition], leftIndex, partition - 1);
            int rightCost = calculateMinCost(cuts, cuts[partition], endStick, partition + 1, rightIndex);
            // Cost of making the current cut
            int currentCost = (endStick - startStick) + leftCost + rightCost;
            // Track the minimum cost across all possible cuts
            minCost = Math.min(minCost, currentCost);
        }

        return minCost;
    }
}



//Better Approach

class Solution {
    /*
     * Memoization:
     * dp[leftIndex][rightIndex] stores the minimum cost required to perform
     * all cuts between indices leftIndex and rightIndex (inclusive).
     *
     * Meaning of values:
     * - null → this subproblem has NOT been computed yet
     * - value → minimum cost to perform all cuts within this range
     *
     * Important:
     * - Although startStick and endStick are passed as parameters,
     *   they are implicitly determined by leftIndex and rightIndex
     *   because the cuts array is sorted.
     *
     *     → startStick = (leftIndex > 0) ? cuts[leftIndex - 1] : 0
     *     → endStick   = (rightIndex < cuts.length - 1) ? cuts[rightIndex + 1] : n
     *
     * - Hence, for a given (leftIndex, rightIndex), the segment boundaries
     *   are fixed and do not need to be stored separately in the DP state.
     *
     * - Therefore, dp depends only on indices, not on startStick/endStick.
     *
     * If a state is already computed, return it directly.
     * Otherwise, compute and store it in dp[leftIndex][rightIndex]
     * to avoid recomputation of overlapping subproblems.
     */
    private Integer[][] dp;

    public int minCost(int n, int[] cuts) {
        dp = new Integer[cuts.length][cuts.length];
        Arrays.sort(cuts);
        return calculateMinCost(cuts, 0, n, 0, cuts.length - 1);
    }

    private int calculateMinCost(int[] cuts, int startStick, int endStick, int leftIndex, int rightIndex) {
        if (leftIndex > rightIndex) {
            return 0;
        }

        if (dp[leftIndex][rightIndex] != null) {
            return dp[leftIndex][rightIndex];
        }

        int minCost = Integer.MAX_VALUE;

        for (int partition = leftIndex; partition <= rightIndex; partition++) {
            int leftCost = calculateMinCost(cuts, startStick, cuts[partition], leftIndex, partition - 1);
            int rightCost = calculateMinCost(cuts, cuts[partition], endStick, partition + 1, rightIndex);
            int currentCost = (endStick - startStick) + leftCost + rightCost;
            minCost = Math.min(minCost, currentCost);
        }

        return dp[leftIndex][rightIndex] = minCost;
    }
}


