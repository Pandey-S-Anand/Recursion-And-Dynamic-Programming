//Optimal implementation 

class Solution {
    public int perfectSum(int arr[], int targetSum) {
        // Since dp[i][*] depends on dp[i+1][*], we use two arrays (currentRow and nextRow) to represent current and next states
        int[] nextRow = new int[targetSum + 1];
        int[] currentRow = new int[targetSum + 1];

        nextRow[0] = 1;

        for (int i = arr.length - 1; i >= 0; i--) {
            for (int sum = 0; sum <= targetSum; sum++) {
                int count = 0;
                if (sum >= arr[i]) {
                    count = nextRow[sum - arr[i]];
                }
                count += nextRow[sum];
                currentRow[sum] = count;
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[targetSum];
    }
}
