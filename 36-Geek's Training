//Naive implementation

class Solution {
    public int maximumPoints(int[][] points) {
        /*
         * dp[day][prevActivity] represents the maximum points collected from day 'day' to the 'last' day 
         * while ensuring that the activity performed on day 'day' is not the same as lastActivity (i.e the task performed on the previous day).
         */
        int[][] dp = new int[points.length + 1][4];

        dp[points.length][0] = dp[points.length][1] = dp[points.length][2] = dp[points.length][3] = 0;

        for (int day = points.length - 1; day >= 0; day--) {
            for (int prevActivity = 3; prevActivity >= 0; prevActivity--) {
                int activity0Points = Integer.MIN_VALUE;
                int activity1Points = Integer.MIN_VALUE;
                int activity2Points = Integer.MIN_VALUE;

                if (prevActivity != 0) {
                    activity0Points = points[day][0] + dp[day + 1][0];
                }

                if (prevActivity != 1) {
                    activity1Points = points[day][1] + dp[day + 1][1];
                }

                if (prevActivity != 2) {
                    activity2Points = points[day][2] + dp[day + 1][2];
                }

                dp[day][prevActivity] = Math.max(activity0Points, Math.max(activity1Points, activity2Points));
            }
        }

        return dp[0][3];
    }
}



//Optimal implementation

class Solution {
    public int maximumPoints(int[][] points) {
        int[] currentDay = new int[4];
        int[] nextDay = new int[4];

        nextDay[0] = nextDay[1] = nextDay[2] = nextDay[3] = 0;

        for (int day = points.length - 1; day >= 0; day--) {
            for (int prevActivity = 3; prevActivity >= 0; prevActivity--) {
                int activity0Points = Integer.MIN_VALUE;
                int activity1Points = Integer.MIN_VALUE;
                int activity2Points = Integer.MIN_VALUE;

                if (prevActivity != 0) {
                    activity0Points = points[day][0] + nextDay[0];
                }

                if (prevActivity != 1) {
                    activity1Points = points[day][1] + nextDay[1];
                }

                if (prevActivity != 2) {
                    activity2Points = points[day][2] + nextDay[2];
                }

                currentDay[prevActivity] = Math.max(activity0Points, Math.max(activity1Points, activity2Points));
            }

            int[] temp = currentDay;
            currentDay = nextDay;
            nextDay = temp;
        }

        return nextDay[3];
    }
}

