//Bruteforce Approach

class Solution {
    public int maximumPoints(int[][] points) {
        return maxPoints(points, 0, 3);
    }

    private int maxPoints(int[][] points, int day, int prevActivity) {
        /*
         * Base case:
         * - If all days are processed, no more points can be earned
         */
        if (day == points.length) {
            return 0;
        }

        int activity0Points = Integer.MIN_VALUE;
        int activity1Points = Integer.MIN_VALUE;
        int activity2Points = Integer.MIN_VALUE;

        // Try all activities except the one done on previous day
        
        // Activity 0
        if (prevActivity != 0) {
            activity0Points = points[day][0] + maxPoints(points, day + 1, 0);
        }

        // Activity 1
        if (prevActivity != 1) {
            activity1Points = points[day][1] + maxPoints(points, day + 1, 1);
        }

        // Activity 2
        if (prevActivity != 2) {
            activity2Points = points[day][2] + maxPoints(points, day + 1, 2);
        }

        //  Choose the best among all valid activities
        return Math.max(activity0Points, Math.max(activity1Points, activity2Points));
    }
}



//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[day][prevActivity] stores the maximum points that can be earned
    * starting from the given day, given the activity performed on the previous day.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → maximum points achievable from this state
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[day][prevActivity]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int maximumPoints(int[][] points) {
        dp = new Integer[points.length][4];
        return maxPoints(points, 0, 3);
    }

    private int maxPoints(int[][] points, int day, int prevActivity) {
        if (day == points.length) {
            return 0;
        }

        if (dp[day][prevActivity] != null) {
            return dp[day][prevActivity];
        }

        int activity0Points = Integer.MIN_VALUE;
        int activity1Points = Integer.MIN_VALUE;
        int activity2Points = Integer.MIN_VALUE;

        if (prevActivity != 0) {
            activity0Points = points[day][0] + maxPoints(points, day + 1, 0);
        }

        if (prevActivity != 1) {
            activity1Points = points[day][1] + maxPoints(points, day + 1, 1);
        }

        if (prevActivity != 2) {
            activity2Points = points[day][2] + maxPoints(points, day + 1, 2);
        }

        return dp[day][prevActivity] = Math.max(activity0Points, Math.max(activity1Points, activity2Points));
    }
}


