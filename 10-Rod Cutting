//Optimal implementation

class Solution {
    public int cutRod(int[] price) {
        int rodLength = price.length;
        // Since dp[pieceLength][*] depends on dp[pieceLength][*]  and dp[pieceLength+1][*], we use two arrays (currentRow and nextRow)
        int[] currentRow = new int[rodLength + 1];
        int[] nextRow = new int[rodLength + 1];

        for (int rodSize = 1; rodSize <= rodLength; rodSize++) {
            nextRow[rodSize] = Integer.MIN_VALUE;
        }

        for (int pieceLength = rodLength; pieceLength >= 1; pieceLength--) {
            currentRow[0] = 0;
            for (int rodSize = 1; rodSize <= rodLength; rodSize++) {
                int include = Integer.MIN_VALUE;

                if (pieceLength <= rodSize) {
                    include = currentRow[rodSize - pieceLength];

                    if (include != Integer.MIN_VALUE) {
                        include += price[pieceLength - 1];
                    }
                }

                int exclude = nextRow[rodSize];

                currentRow[rodSize] = Math.max(include, exclude);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[rodLength];
    }
}
