//Bruteforce Approach

class Solution {
    public int cutRod(int[] price) {
        return cutRod(1, price.length, price);
    }

    private int cutRod(int pieceLength, int rodLength, int[] price) {
        /*
        * Base Case 1:
        * If the remaining rod length becomes 0,
        * no further cuts can be made → return 0 revenue.
        */

        if (rodLength == 0) {
            return 0;
        }

        /*
        * Base Case 2:
        * If all possible piece lengths are exhausted but rod is still remaining,
        * it means we cannot form a valid cut combination.
        * Return Integer.MIN_VALUE to indicate an invalid state.
        */
        if (pieceLength == price.length + 1) {
            return Integer.MIN_VALUE;
        }

        int include = Integer.MIN_VALUE;

        /*
        * Option 1: Include the current piece length
        * We can include it only if it fits in the remaining rod.
        * Since this is an unbounded problem, we stay at the same pieceLength
        * to allow multiple cuts of the same size.
        */
        if (pieceLength <= rodLength) {
            include = cutRod(pieceLength, rodLength - pieceLength, price);

            if (include != Integer.MIN_VALUE) {
                include += price[pieceLength - 1]; // If it's possible to include the current piece, add its value to the total
            }
        }

        /*
        * Option 2: Exclude the current piece length
        * Move to the next possible piece length.
        */
        int exclude = cutRod(pieceLength + 1, rodLength, price);

        return Math.max(include, exclude);
    }
}


//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[pieceLength][rodLength] stores the maximum revenue that can be obtained
    * using piece lengths from pieceLength → n with remaining rod length = rodLength.
    *
    * Meaning of values:
    * - null  → this state has NOT been computed yet
    * - value → maximum achievable revenue for this state
    * - Integer.MIN_VALUE → invalid state (cannot form exact rod length)
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute the result and store it in dp
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[][] dp;

    public int cutRod(int[] price) {
        dp = new Integer[price.length + 1][price.length + 1];
        return cutRod(1, price.length, price);
    }

    private int cutRod(int pieceLength, int rodLength, int[] price) {
        if (rodLength == 0) {
            return 0;
        }

        if (pieceLength == price.length + 1) {
            return Integer.MIN_VALUE;
        }

        if (dp[pieceLength][rodLength] != null) {
            return dp[pieceLength][rodLength];
        }

        int include = Integer.MIN_VALUE;

        if (pieceLength <= rodLength) {
            include = cutRod(pieceLength, rodLength - pieceLength, price);

            if (include != Integer.MIN_VALUE) {
                include += price[pieceLength - 1];
            }
        }

        int exclude = cutRod(pieceLength + 1, rodLength, price);

        return dp[pieceLength][rodLength] = Math.max(include, exclude);
    }
}


