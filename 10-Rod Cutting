//Naive implementation 

class Solution {
    public int cutRod(int[] price) {
        int rodLength = price.length;

        /*
        * dp[pieceLength][rodSize] represents:
        * "Maximum revenue that can be obtained by cutting a rod of length = rodSize
        * using piece lengths from pieceLength → n."
        *
        * If it is not possible to form the exact rod length, the value is Integer.MIN_VALUE.
        */
        int[][] dp = new int[rodLength + 2][rodLength + 1];

        for (int pieceLength = 1; pieceLength <= rodLength; pieceLength++) {
            dp[pieceLength][0] = 0;
        }

        for (int rodSize = 1; rodSize <= rodLength; rodSize++) {
            dp[rodLength + 1][rodSize] = Integer.MIN_VALUE;
        }

        for (int pieceLength = rodLength; pieceLength >= 1; pieceLength--) {
            for (int rodSize = 1; rodSize <= rodLength; rodSize++) {
                int include = Integer.MIN_VALUE;

                if (pieceLength <= rodSize) {
                    include = dp[pieceLength][rodSize - pieceLength];

                    if (include != Integer.MIN_VALUE) {
                        include += price[pieceLength - 1];
                    }
                }

                int exclude = dp[pieceLength + 1][rodSize];

                dp[pieceLength][rodSize] = Math.max(include, exclude);
            }
        }

        return dp[1][rodLength];
    }
}


