//Bruteforce Approach

class Solution {
    public int maxProfit(int[] prices) {
        /*
         * Start recursion from day = 0
         * Initially, we are not holding any stock (holdStock = false)
         * We are allowed at most 2 transactions (transactionsRemaining = 2)
         */
        return maxProfit(0, false, 2, prices);
    }

    private int maxProfit(int day, boolean holdStock, int transactionsRemaining, int[] prices) {
        // If all days are processed or no transactions are left, no profit can be made
        if (transactionsRemaining == 0 || day == prices.length) {
            return 0;
        }

        // If we do NOT currently hold a stock
        if (!holdStock) {
            /*
             * Two choices:
             * 1. Buy the stock today:
             *    - Deduct price from profit since buying is a cost.
             *    - We DO NOT reduce 'transactionsRemaining' here because transaction is not yet complete.
             *
             * 2. Skip buying today:
             *    - Move to next day with same state.
             */
            int buy = -prices[day] + maxProfit(day + 1, true, transactionsRemaining, prices);
            int skipBuy = maxProfit(day + 1, false, transactionsRemaining, prices);
            return Math.max(buy, skipBuy);
        }

        /*
         * If we currently HOLD a stock:
         * Two choices:
         * 1. Sell the stock today:
         *    - Add price to profit since we are selling.
         *    - Decrease 'transactionsRemaining' by 1 because the transaction is now complete (buy + sell).
         *
         * 2. Skip selling today:
         *    - - Move to next day with same state.
         */
        int sell = prices[day] + maxProfit(day + 1, false, transactionsRemaining - 1, prices);
        int skipSell = maxProfit(day + 1, true, transactionsRemaining, prices);

        return Math.max(sell, skipSell);
    }
}


//Better Approach

class Solution {
    /*
    * dp[day][holdStock][transactionsRemaining] represents the maximum profit achievable 
    * from day 'day' to the end of the price list, given:
    * 
    * - holdStock:
    *     0 → You do NOT currently hold any stock.
    *     1 → You ARE currently holding a stock.
    *
    * - transactionsRemaining:
    *     Number of transactions STILL allowed (maximum of 2 transactions allowed).
    *     Each transaction is defined as one buy followed by one sell.
    *
    * Decision-making:
    * 
    * If holdStock == 0:
    *   → You can either:
    *     1. Buy the stock: Subtract the current price and move to the next day with holdStock = 1.
    *     2. Skip buying: Move to the next day with holdStock = 0.
    * 
    * If holdStock == 1:
    *   → You can either:
    *     1. Sell the stock: Add the current price, decrement 'transactionsRemaining' by 1, and move to next day with holdStock = 0.
    *     2. Skip selling: Move to the next day with holdStock = 1.
    */
    private Integer[][][] dp;

    public int maxProfit(int[] prices) {
        dp = new Integer[prices.length][2][3];
        return maxProfit(0, 0, 2, prices);
    }

    private int maxProfit(int day, int holdStock, int transactionsRemaining, int[] prices) {
        if (transactionsRemaining == 0 || day == prices.length) {
            return 0;
        }

        if (dp[day][holdStock][transactionsRemaining] != null) {
            return dp[day][holdStock][transactionsRemaining];
        }

        if (holdStock == 0) {
            int buy = -prices[day] + maxProfit(day + 1, 1, transactionsRemaining, prices);
            int skipBuy = maxProfit(day + 1, 0, transactionsRemaining, prices);
            return dp[day][holdStock][transactionsRemaining] = Math.max(buy, skipBuy);
        }

        int sell = prices[day] + maxProfit(day + 1, 0, transactionsRemaining - 1, prices);
        int skipSell = maxProfit(day + 1, 1, transactionsRemaining, prices);

        return dp[day][holdStock][transactionsRemaining] = Math.max(sell, skipSell);
    }
}


