//Naive Implementation 

class Solution {
    /*
    * dp[day][holdStock][transactionsRemaining] represents:
    * "Maximum profit that can be achieved from day 'day' to the end,
    * given the current holding state and remaining transactions."
    *
    * State meaning:
    * - holdStock = 0 → we do NOT hold a stock (can buy or skip)
    * - holdStock = 1 → we currently hold a stock (can sell or skip)
    *
    * - transactionsRemaining:
    *   Number of transactions (buy + sell pairs) we are still allowed to complete.
    */
    public int maxProfit(int[] prices) {
        int[][][] dp = new int[prices.length + 1][2][3];

        for (int holdStock = 0; holdStock <= 1; holdStock++) {
            for (int txnRemaining = 1; txnRemaining <= 2; txnRemaining++) {
                dp[prices.length][holdStock][txnRemaining] = 0;
            }
        }

        for (int day = 0; day < prices.length; day++) {
            for (int holdStock = 0; holdStock <= 1; holdStock++) {
                dp[day][holdStock][0] = 0;
            }
        }

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int holdStock = 0; holdStock <= 1; holdStock++) {
                for (int txnRemaining = 1; txnRemaining <= 2; txnRemaining++) {
                    int profit = 0;

                    if (holdStock == 0) {
                        int buy = -prices[day] + dp[day + 1][1][txnRemaining];
                        int skipBuy = dp[day + 1][0][txnRemaining];
                        profit = Math.max(buy, skipBuy);
                    } else {
                        int sell = prices[day] + dp[day + 1][0][txnRemaining - 1];
                        int skipSell = dp[day + 1][1][txnRemaining];
                        profit = Math.max(sell, skipSell);
                    }

                    dp[day][holdStock][txnRemaining] = profit;
                }
            }
        }

        return dp[0][0][2];
    }
}


//Better implementation 

class Solution {
    public int maxProfit(int[] prices) {
        int[][][] dp = new int[prices.length + 1][2][3];

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int txnRemaining = 1; txnRemaining <= 2; txnRemaining++) {
                int profit = 0;

                int buy = -prices[day] + dp[day + 1][1][txnRemaining];
                int skipBuy = dp[day + 1][0][txnRemaining];
                dp[day][0][txnRemaining] = Math.max(buy, skipBuy);

                int sell = prices[day] + dp[day + 1][0][txnRemaining - 1];
                int skipSell = dp[day + 1][1][txnRemaining];
                dp[day][1][txnRemaining] = Math.max(sell, skipSell);
            }
        }

        return dp[0][0][2];
    }
}


//Optimal implementation (space optimised : 3D to 2 2D array)

class Solution {
    public int maxProfit(int[] prices) {
        // Since dp[day][*][*] depends only on dp[day + 1][*][*], we use two 2D arrays (currentRow and nextRow) instead of a full 3D dp array
        int[][] currentRow = new int[2][3];
        int[][] nextRow = new int[2][3];

        for (int day = prices.length - 1; day >= 0; day--) {
            for (int txnRemaining = 1; txnRemaining <= 2; txnRemaining++) {
                int profit = 0;

                int buy = -prices[day] + nextRow[1][txnRemaining];
                int skipBuy = nextRow[0][txnRemaining];
                currentRow[0][txnRemaining] = Math.max(buy, skipBuy);

                int sell = prices[day] + nextRow[0][txnRemaining - 1];
                int skipSell = nextRow[1][txnRemaining];
                currentRow[1][txnRemaining] = Math.max(sell, skipSell);
            }

            int[][] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[0][2];
    }
}
