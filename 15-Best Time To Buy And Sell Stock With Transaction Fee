//Bruteforce Approach

class Solution {
    public int maxProfit(int[] prices, int fee) {
        /*
         * Start recursion from day = 0.
         * Initially, we are not holding any stock (holdStock = false).
         */
        return maxProfit(0, false, fee, prices);
    }

    private int maxProfit(int day, boolean holdStock, int fee, int[] prices) {
        // If all days are processed, no further profit can be made
        if (day == prices.length) {
            return 0;
        }

        // If we do NOT currently hold a stock
        if (!holdStock) {
            /*
             * Two choices:
             * 1. Buy the stock today:
             *    - Profit decreases by prices[day] (cost of buying).
             *    - No fee is applied here.
             *
             * 2. Skip buying today:
             *    - Move to next day with same state.
             */
            int buy = -prices[day] + maxProfit(day + 1, true, fee, prices);
            int skipBuy = maxProfit(day + 1, false, fee, prices);
            return Math.max(buy, skipBuy);
        }

        /*
         * If we currently HOLD a stock:
         * Two choices:
         * 1. Sell the stock today:
         *    - Profit increases by prices[day].
         *    - Transaction fee is deducted here (prices[day] - fee),
         *      since a buy + sell pair completes one transaction.
         *
         * 2. Skip selling today:
         *    - Move to next day with same state.
         */
        int sell = prices[day] - fee + maxProfit(day + 1, false, fee, prices);
        int skipSell = maxProfit(day + 1, true, fee, prices);

        return Math.max(sell, skipSell);
    }
}


//Better Approach

class Solution {
    /*
     * Memoization:
     * dp[day][holdStock] stores the maximum profit that can be achieved
     * starting from the given day with the current holding state,
     * where each completed transaction (buy + sell) incurs a fixed fee
     * applied at the time of selling.
     *
     * Meaning of values:
     * - null  → this state has NOT been computed yet
     * - value → maximum profit achievable for this state
     *
     * State definition:
     * - holdStock = 0 → we do NOT hold a stock (can buy or skip)
     * - holdStock = 1 → we currently hold a stock (can sell or skip)
     *
     * If a state is already computed, return it directly.
     * Otherwise, compute the result and store it in dp
     * to avoid recomputation of overlapping subproblems.
     */
    private Integer[][] dp;

    public int maxProfit(int[] prices, int fee) {
        dp = new Integer[prices.length][2];
        return maxProfit(0, 0, fee, prices);
    }

    private int maxProfit(int day, int holdStock, int fee, int[] prices) {
        if (day == prices.length) {
            return 0;
        }

        if (dp[day][holdStock] != null) {
            return dp[day][holdStock];
        }

        if (holdStock == 0) {
            int buy = -prices[day] + maxProfit(day + 1, 1, fee, prices);
            int skipBuy = maxProfit(day + 1, 0, fee, prices);
            return dp[day][holdStock] = Math.max(buy, skipBuy);
        }

        int sell = prices[day] - fee + maxProfit(day + 1, 0, fee, prices);
        int skipSell = maxProfit(day + 1, 1, fee, prices);

        return dp[day][holdStock] = Math.max(sell, skipSell);
    }
}


