//Naive Implementation 

class Solution {
    public int coinChange(int[] coins, int amount) {
        /*
        * dp[i][sum] represents:
        * "Minimum number of coins required to form the given sum
        * using coins from index i to n-1."
        *
        * If it is not possible to form the sum, the value is Integer.MAX_VALUE.
        */
        int[][] dp = new int[coins.length + 1][amount + 1];

        for (int i = 0; i <= coins.length; i++) {
            dp[i][0] = 0;
        }

        for (int sum = 1; sum <= amount; sum++) {
            dp[coins.length][sum] = Integer.MAX_VALUE;
        }

        for (int i = coins.length - 1; i >= 0; i--) {
            for (int sum = 1; sum <= amount; sum++) {
                int include = Integer.MAX_VALUE;

                if (coins[i] <= sum) {
                    include = dp[i][sum - coins[i]];
                    if (include != Integer.MAX_VALUE) {
                        include += 1;
                    }
                }

                int exclude = dp[i + 1][sum];

                dp[i][sum] = Math.min(include, exclude);
            }
        }

        return dp[0][amount] == Integer.MAX_VALUE ? -1 : dp[0][amount];
    }
}


