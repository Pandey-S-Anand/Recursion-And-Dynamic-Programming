//Optimal implementation

class Solution {
    public int coinChange(int[] coins, int amount) {
        // Since dp[i][*] depends on dp[i][*] and dp[i+1][*], we use two arrays (currentRow and nextRow) to represent current and next states
        int[] currentRow = new int[amount + 1];
        int[] nextRow = new int[amount + 1];

        for (int sum = 1; sum <= amount; sum++) {
            nextRow[sum] = Integer.MAX_VALUE;
        }

        for (int i = coins.length - 1; i >= 0; i--) {
            for (int sum = 1; sum <= amount; sum++) {
                int include = Integer.MAX_VALUE;

                if (coins[i] <= sum) {
                    include = currentRow[sum - coins[i]];
                    if (include != Integer.MAX_VALUE) {
                        include += 1;
                    }
                }

                int exclude = nextRow[sum];

                currentRow[sum] = Math.min(include, exclude);
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[amount] == Integer.MAX_VALUE ? -1 : nextRow[amount];
    }
}
