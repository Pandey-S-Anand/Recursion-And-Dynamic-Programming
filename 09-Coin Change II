//Naive Implementation

class Solution {
    public int change(int amount, int[] coins) {
        // dp[i][sum] → number of ways to form 'sum' using coins from 'i' → n - 1 (unbounded)
        int[][] dp = new int[coins.length + 1][amount + 1];

        dp[coins.length][0] = 1;

        for (int i = 0; i < coins.length; i++) {
            dp[i][0] = 1;
        }

        for (int sum = 1; sum <= amount; sum++) {
            dp[coins.length][sum] = 0;
        }

        for (int i = coins.length - 1; i >= 0; i--) {
            for (int sum = 1; sum <= amount; sum++) {
                if (coins[i] <= sum) {
                    dp[i][sum] = dp[i][sum - coins[i]];
                }

                dp[i][sum] += dp[i + 1][sum];
            }
        }

        return dp[0][amount];
    }
}


//Better Implementation 

class Solution {
    public int change(int amount, int[] coins) {
        int[][] dp = new int[coins.length + 1][amount + 1];

        for (int i = 0; i <= coins.length; i++) {
            dp[i][0] = 1;
        }

        for (int i = coins.length - 1; i >= 0; i--) {
            for (int sum = 1; sum <= amount; sum++) {
                if (coins[i] <= sum) {
                    dp[i][sum] = dp[i][sum - coins[i]];
                }

                dp[i][sum] += dp[i + 1][sum];
            }
        }

        return dp[0][amount];
    }
}


//Optimal implementation

class Solution {
    public int change(int amount, int[] coins) {
        // Since dp[i][*] depends on dp[i][*] and dp[i+1][*], we use two arrays (currentRow and nextRow) to represent current and next states
        int[] currentRow = new int[amount + 1];
        int[] nextRow = new int[amount + 1];

        nextRow[0] = 1;

        for (int i = coins.length - 1; i >= 0; i--) {
            currentRow[0] = 1;
            for (int sum = 1; sum <= amount; sum++) {
                int include = 0;
                if (coins[i] <= sum) {
                    include = currentRow[sum - coins[i]];
                }

                int exclude = nextRow[sum];

                currentRow[sum] = include + exclude;
            }

            int[] temp = currentRow;
            currentRow = nextRow;
            nextRow = temp;
        }

        return nextRow[amount];
    }
}
