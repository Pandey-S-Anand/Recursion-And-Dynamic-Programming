//Bruteforce Approach

class Solution {
    public int minCostClimbingStairs(int[] cost) {
        // Start from step 0 or step 1 and return the minimum cost
        return Math.min(minCostClimbingStairs(cost, 0), minCostClimbingStairs(cost, 1));
    }

    private int minCostClimbingStairs(int[] cost, int stair) {
        // If we reach or exceed the top, no cost is needed
        if (stair >= cost.length) {
            return 0;
        }

        // Add current stair cost and add minimum cost of taking 1 or 2 steps
        return cost[stair] + Math.min(minCostClimbingStairs(cost, stair + 1), minCostClimbingStairs(cost, stair + 2));
    }
}



//Better Approach

class Solution {
    /*
    * Memoization:
    * dp[stair] stores the minimum cost required to reach the top
    * starting from the given stair.
    *
    * Meaning of values:
    * - null → this state has NOT been computed yet
    * - value → minimum cost to reach the top from this stair
    *
    * If a state is already computed, return it directly.
    * Otherwise, compute and store it in dp[stair]
    * to avoid recomputation of overlapping subproblems.
    */
    private Integer[] dp;

    public int minCostClimbingStairs(int[] cost) {
        dp = new Integer[cost.length];
        return Math.min(minCostClimbingStairs(cost, 0), minCostClimbingStairs(cost, 1));
    }

    private int minCostClimbingStairs(int[] cost, int stair) {
        if (stair >= cost.length) {
            return 0;
        }

        if (dp[stair] != null) {
            return dp[stair];
        }

        return dp[stair] = cost[stair] + Math.min(minCostClimbingStairs(cost, stair + 1), minCostClimbingStairs(cost, stair + 2));
    }
}



//Optimal Approach

//Naive implementation

class Solution {
    public int minCostClimbingStairs(int[] cost) {
        /*
         * dp[i] will store the minimum cost needed to reach the top starting from
         * stair 'i', where you can either move one or two steps up at each move.
         */
        int[] dp = new int[cost.length + 2];

        /**
        * Base case:
        * - dp[cost.length] and dp[cost.length + 1] represent reaching and crossing the top of the staircase respectively.
        * - Once we are at top or crossed the top of the staircase, no further cost is required.
        * - Hence, both are initialized to 0.
        */
        dp[cost.length] = dp[cost.length + 1] = 0;

        for (int stair = cost.length - 1; stair >= 0; stair--) {
            dp[stair] = cost[stair] + Math.min(dp[stair + 1], dp[stair + 2]);
        }

        return Math.min(dp[0], dp[1]);
    }
}


//Optimal implementation

class Solution {
    public int minCostClimbingStairs(int[] cost) {
        int[] dp = new int[cost.length + 1];

        dp[cost.length] = 0; // dp[cost.length] represent reaching the top of the staircase, no further cost is required.
        dp[cost.length - 1] = cost[cost.length - 1]; //Only one move is possible (1-step to the top), so we pay the cost of the last stair.

        for (int stair = cost.length - 2; stair >= 0; stair--) {
            dp[stair] = cost[stair] + Math.min(dp[stair + 1], dp[stair + 2]);
        }

        return Math.min(dp[0], dp[1]);
    }
}
